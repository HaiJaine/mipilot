    verify_sha256_sidecar "${output_dir}/geosite.dat" "${output_dir}/geosite.dat.sha256sum"
}

validate_combined_update() {
  local staged_core="$1"
  local country_file="$2"
  local geosite_file="$3"
  local validation_dir

  validation_dir="$(mktemp -d /tmp/mihomo-combined-validation.XXXXXX)" || return 1
  sudo -n cp -a "${CONFIG_DIR}/." "$validation_dir/" || {
    sudo -n rm -rf -- "$validation_dir"
    return 1
  }
  sudo -n install -m 644 "$country_file" "${validation_dir}/Country.mmdb" || {
    sudo -n rm -rf -- "$validation_dir"
    return 1
  }
  sudo -n install -m 644 "$geosite_file" "${validation_dir}/GeoSite.dat" || {
    sudo -n rm -rf -- "$validation_dir"
    return 1
  }
  sudo -n "$staged_core" -t -d "$validation_dir"
  local status=$?
  sudo -n rm -rf -- "$validation_dir"
  return "$status"
}

recover_combined_update() {
  local restore_core="$1"
  local restore_geo="$2"
  local expected_old_version="$3"
  local restored=0

  if (( restore_core == 1 )); then restore_component_rollback core || restored=1; fi
  if (( restore_geo == 1 )); then restore_component_rollback geo || restored=1; fi
  if (( restored == 0 )) && restart_mihomo_with_progress && \
     wait_mihomo_with_progress 3 "$expected_old_version"; then
    echo "组件更新失败, 已恢复更新前的内核和地理数据."
    return 0
  fi
  echo "严重错误: 组合更新失败且自动恢复未完成. 回退目录: ${ROLLBACK_DIR}."
  return 1
}

update_all_from_files() {
  local archive="$1"
  local country_file="$2"
  local geosite_file="$3"
  local source_label="${4:-本地文件}"
  local staged_core
  local current_version
  local new_version
  local current_country_hash=""
  local current_geosite_hash=""
  local new_country_hash
  local new_geosite_hash
  local core_changed=1
  local geo_changed=1
  local status

  gzip -t "$archive" || return 1
  staged_core="$(mktemp /tmp/mihomo-combined-core.XXXXXX)" || return 1
  gzip -dc "$archive" >"$staged_core" || return 1
  chmod 755 "$staged_core"
  new_version="$("$staged_core" -v 2>/dev/null | awk 'NR == 1 { print $3; exit }')"
  current_version="$(current_core_version)"
  [[ -n $new_version && $new_version == v* ]] || {
    rm -f -- "$staged_core"
    return 1
  }
  [[ $new_version == "$current_version" ]] && core_changed=0
  if (( core_changed == 1 )) && [[ -n $current_version ]] && ! version_is_newer "${new_version#v}" "${current_version#v}"; then
    read_line_or_back "组合更新包含内核降级 ${current_version} -> ${new_version}, 是否继续? (y/N): "
    status=$?
    if (( status != 0 )); then rm -f -- "$staged_core"; return "$status"; fi
    case "${INPUT_LINE,,}" in y|yes) ;; *) rm -f -- "$staged_core"; return 130 ;; esac
  fi

  if sudo test -f "${CONFIG_DIR}/Country.mmdb"; then
    current_country_hash="$(sudo sha256sum "${CONFIG_DIR}/Country.mmdb" | awk '{print $1}')"
  fi
  if sudo test -f "${CONFIG_DIR}/GeoSite.dat"; then
    current_geosite_hash="$(sudo sha256sum "${CONFIG_DIR}/GeoSite.dat" | awk '{print $1}')"
  fi
  new_country_hash="$(sha256sum "$country_file" | awk '{print $1}')"
  new_geosite_hash="$(sha256sum "$geosite_file" | awk '{print $1}')"
  if [[ $current_country_hash == "$new_country_hash" && $current_geosite_hash == "$new_geosite_hash" ]]; then
    geo_changed=0
  fi
  if (( core_changed == 0 && geo_changed == 0 )); then
    rm -f -- "$staged_core"
    echo "内核和地理数据均与当前版本相同, 无需更新."
    return 0
  fi

  run_blocking "正在验证 ${source_label} 中的内核和地理数据" 60 \
    validate_combined_update "$staged_core" "$country_file" "$geosite_file" || {
    rm -f -- "$staged_core"
    return 1
  }
  if (( core_changed == 1 )); then save_component_rollback core || return 1; fi
  if (( geo_changed == 1 )); then save_component_rollback geo || return 1; fi
  if ! stop_mihomo_for_update; then
    rm -f -- "$staged_core"
    echo "无法停止 Mihomo 服务, 组合更新已取消."
    return 1
  fi

  if (( core_changed == 1 )); then
    atomic_install_file 755 "$staged_core" "$MIHOMO_BIN" || {
      recover_combined_update "$core_changed" "$geo_changed" "$current_version" || true
      rm -f -- "$staged_core"
      return 1
    }
  fi
  if (( geo_changed == 1 )); then
    atomic_install_file 644 "$country_file" "${CONFIG_DIR}/Country.mmdb" &&
      atomic_install_file 644 "$geosite_file" "${CONFIG_DIR}/GeoSite.dat" || {
        recover_combined_update "$core_changed" "$geo_changed" "$current_version" || true
        rm -f -- "$staged_core"
        return 1
      }
  fi
  rm -f -- "$staged_core"
  if ! run_cancellable_named "正在验证组合更新配置" 45 \
       sudo -n "$MIHOMO_BIN" -t -d "$CONFIG_DIR" ||
     ! restart_mihomo_with_progress ||
     ! wait_mihomo_with_progress 3 "$new_version"; then
    recover_combined_update "$core_changed" "$geo_changed" "$current_version" || true
    return 1
  fi
  cleanup_expired_rollbacks || true
  echo "内核和地理数据已完成组合更新."
}

