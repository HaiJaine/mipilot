rollback_config() {
  local backup="$1"

  echo "正在恢复上一份配置..."
  if ! atomic_install_file 600 "$backup" "$CONFIG_FILE"; then
    echo "回滚失败: 无法恢复配置文件 ${backup}"
    return 1
  fi
  if ! restart_mihomo_with_progress; then
    echo "回滚配置已恢复, 但 Mihomo 服务重启失败."
    return 1
  fi
  echo "旧配置已恢复, Mihomo 服务已重新启动."
}

create_curl_url_config() {
  local url="$1"
  local target="$2"
  local escaped

  [[ $url == http://* || $url == https://* ]] || return 1
  [[ $url != *$'\n'* && $url != *$'\r'* ]] || return 1
  escaped="${url//\\/\\\\}"
  escaped="${escaped//\"/\\\"}"
  umask 077
  printf 'url = "%s"\n' "$escaped" >"$target"
  chmod 600 "$target"
}

render_local_api_config() {
  local input_file="$1"
  local output_file="$2"

  awk '
    /^external-controller:[[:space:]]*/ {
      if (!controller_seen) {
        print "external-controller: '\''127.0.0.1:9090'\''"
        controller_seen = 1
      }
      next
    }
    { print }
    END {
      if (!controller_seen) {
        print ""
        print "external-controller: '\''127.0.0.1:9090'\''"
      }
    }
  ' "$input_file" >"$output_file"
}

download_and_apply_subscription() {
  local url="$1"
  local temporary
  local curl_config
  local tun_temporary
  local tun_override
  local region_temporary
  local api_temporary
  local backup
  local status

  ensure_sudo_access || return 1
  temporary="$(mktemp /tmp/mihomo-config.XXXXXX.yaml)" || return
  curl_config="$(mktemp /tmp/mipilot-subscription-curl.XXXXXX)" || {
    rm -f -- "$temporary"
    return 1
  }
  if ! create_curl_url_config "$url" "$curl_config"; then
    rm -f -- "$temporary" "$curl_config"
    echo "订阅地址无效, 仅支持不含控制字符的 HTTP/HTTPS 地址."
    return 1
  fi
  backup=""

  run_cancellable_named "正在下载订阅" 125 curl \
    -fL \
    -sS \
    --show-error \
    --connect-timeout 20 \
    --max-time 120 \
    -H 'User-Agent: clash.meta' \
    --config "$curl_config" \
    -o "$temporary"
  status=$?
  rm -f -- "$curl_config"
  if (( status == 130 )); then
    rm -f -- "$temporary"
    return 130
  fi
  if (( status != 0 )); then
    rm -f -- "$temporary"
    echo "订阅下载失败, 现有配置未改变."
    return 1
  fi

  if sudo test -s "$TUN_STATE_FILE"; then
    tun_override="$(sudo head -n 1 "$TUN_STATE_FILE")"
    if [[ $tun_override == true || $tun_override == false ]]; then
      tun_temporary="$(mktemp /tmp/mihomo-tun-override.XXXXXX.yaml)" || {
        rm -f -- "$temporary"
        return 1
      }
      if ! render_tun_config "$temporary" "$tun_temporary" "$tun_override"; then
        rm -f -- "$temporary" "$tun_temporary"
        echo "无法将已保存的 TUN 状态合并到新订阅, 现有配置未改变."
        return 1
      fi
      mv -f -- "$tun_temporary" "$temporary"
    fi
  fi

  if sudo test -s "$REGION_STATE_FILE"; then
    region_temporary="$(mktemp /tmp/mihomo-region-override.XXXXXX.yaml)" || {
      rm -f -- "$temporary"
      return 1
    }
    echo "正在重新合并已保存的地区策略组..."
    if ! apply_region_groups_to_config "$temporary" "$region_temporary" "$REGION_STATE_FILE"; then
      rm -f -- "$temporary" "$region_temporary"
      echo "无法将地区策略组合并到新订阅, 现有配置未改变."
      return 1
    fi
    mv -f -- "$region_temporary" "$temporary"
  fi

  api_temporary="$(mktemp /tmp/mihomo-api-override.XXXXXX.yaml)" || {
    rm -f -- "$temporary"
    return 1
  }
  if ! render_local_api_config "$temporary" "$api_temporary"; then
    rm -f -- "$temporary" "$api_temporary"
    echo "无法将本机API设置合并到新订阅, 现有配置未改变."
    return 1
  fi
  mv -f -- "$api_temporary" "$temporary"

  run_cancellable_named "正在验证新订阅配置" 45 \
    sudo -n "$MIHOMO_BIN" -t -d "$CONFIG_DIR" -f "$temporary"
  status=$?
  if (( status == 130 )); then
    rm -f -- "$temporary"
    return 130
  fi
  if (( status != 0 )); then
    rm -f -- "$temporary"
    echo "新配置验证失败, 现有配置未改变."
    return 1
  fi

  echo "新配置验证成功, 正在备份、替换并重启服务; 此阶段不应中断."
  backup="$(create_config_backup subscription)" || {
    rm -f -- "$temporary"
    return 1
  }

  atomic_install_file 600 "$temporary" "$CONFIG_FILE" || {
    rm -f -- "$temporary"
    return 1
  }
  rm -f -- "$temporary"

  if ! run_blocking "正在重启 Mihomo 服务" 35 sudo -n systemctl restart mihomo; then
    if rollback_config "$backup"; then
      echo "新配置启动失败, 已自动回滚."
    else
      echo "新配置启动失败且自动回滚未完成, 请立即检查 ${backup}."
    fi
    return 1
  fi

  if ! run_blocking "正在等待新订阅稳定运行" 15 wait_for_mihomo_stable 2; then
    if rollback_config "$backup"; then
      echo "新配置未能稳定运行, 已自动回滚."
    else
      echo "新配置未稳定运行且自动回滚未完成, 请立即检查 ${backup}."
    fi
    return 1
  fi

  refresh_api_config
  sync_proxy_state
  echo "订阅更新成功."
  echo "备份文件: ${backup}"
}

