    }
  fi

  if sudo test -s "$SUBSCRIPTION_FILE"; then
    active_url="$(sudo head -n 1 "$SUBSCRIPTION_FILE")"
    if [[ -n $active_url ]] && ! grep -Fxq -- "$active_url" "$temporary"; then
      printf '%s\n' "$active_url" >>"$temporary"
    fi
  fi

  atomic_install_file 600 "$temporary" "$SUBSCRIPTION_LIST_FILE"
  status=$?
  rm -f -- "$temporary"
  return "$status"
}

load_subscription_urls() {
  SUBSCRIPTION_URLS=()
  if sudo test -s "$SUBSCRIPTION_LIST_FILE"; then
    mapfile -t SUBSCRIPTION_URLS < <(sudo awk 'NF' "$SUBSCRIPTION_LIST_FILE")
  fi
}

active_subscription_url() {
  if sudo test -s "$SUBSCRIPTION_FILE"; then
    sudo head -n 1 "$SUBSCRIPTION_FILE"
  fi
}

show_subscription_urls() {
  local active_url
  local index
  local marker

  load_subscription_urls
  active_url="$(active_subscription_url)"

  if (( ${#SUBSCRIPTION_URLS[@]} == 0 )); then
    echo "尚未添加订阅地址."
    return
  fi

  echo "订阅列表(* 表示当前激活):"
  for index in "${!SUBSCRIPTION_URLS[@]}"; do
    marker=" "
    if [[ ${SUBSCRIPTION_URLS[$index]} == "$active_url" ]]; then
      marker="*"
    fi
    printf '%s %2d) %s\n' "$marker" "$((index + 1))" "${SUBSCRIPTION_URLS[$index]}"
  done
}

select_subscription_url() {
  local prompt="$1"
  local choice

  SELECTED=""
  load_subscription_urls
  if (( ${#SUBSCRIPTION_URLS[@]} == 0 )); then
    echo "尚未添加订阅地址."
    return 1
  fi

  show_subscription_urls
  if ! read_choice_or_back "$prompt"; then
    return 130
  fi
  choice="$MENU_CHOICE"
  if [[ ! $choice =~ ^[0-9]+$ ]] || (( choice < 1 || choice > ${#SUBSCRIPTION_URLS[@]} )); then
    echo "编号无效."
    return 1
  fi

  SELECTED="${SUBSCRIPTION_URLS[$((choice - 1))]}"
}

append_subscription_url() {
  local url="$1"
  local temporary

  temporary="$(mktemp /tmp/mihomo-subscriptions.XXXXXX)" || return
  if sudo test -f "$SUBSCRIPTION_LIST_FILE"; then
    # shellcheck disable=SC2024
    sudo cat "$SUBSCRIPTION_LIST_FILE" >"$temporary" || {
      rm -f -- "$temporary"
      return 1
    }
  fi
  printf '%s\n' "$url" >>"$temporary"
  atomic_install_file 600 "$temporary" "$SUBSCRIPTION_LIST_FILE"
  local status=$?
  rm -f -- "$temporary"
  return "$status"
}

activate_subscription() {
  local url="$1"
  local previous_marker
  local had_previous=0
  local status

  previous_marker="$(mktemp /tmp/mihomo-active-subscription.XXXXXX)" || return 1
  if sudo test -f "$SUBSCRIPTION_FILE"; then
    sudo install -m 600 "$SUBSCRIPTION_FILE" "$previous_marker" || {
      sudo rm -f -- "$previous_marker"
      return 1
    }
    had_previous=1
  fi
  echo "正在激活订阅并更新对应节点:"
  echo "$url"
  if ! save_subscription_url "$url"; then
    sudo rm -f -- "$previous_marker"
    echo "无法保存激活订阅标记, 当前节点未改变."
    return 1
  fi
  download_and_apply_subscription "$url"
  status=$?
  if (( status != 0 )); then
    if (( had_previous == 1 )); then
      if atomic_install_file 600 "$previous_marker" "$SUBSCRIPTION_FILE"; then
        sudo rm -f -- "$previous_marker"
      else
        echo "警告: 原激活订阅标记恢复失败, 安全副本保留在 ${previous_marker}"
      fi
    else
      sudo rm -f -- "$SUBSCRIPTION_FILE" || true
      sudo rm -f -- "$previous_marker"
    fi
    return "$status"
  fi
  sudo rm -f -- "$previous_marker"
}

add_managed_subscription() {
  local url
  local existing_url
  local status

  echo "订阅链接会显示在当前屏幕上, 但不会进入 shell 历史."
  read_line_or_back "粘贴新订阅链接(Enter提交, Esc返回): "
  status=$?
  if (( status == 130 )); then return 130; fi
  if (( status != 0 )); then
    echo "读取订阅链接失败."
    return 1
  fi
  url="$INPUT_LINE"

  if [[ -z $url ]]; then
    echo "已取消."
    return 130
  fi

  if [[ ! $url =~ ^https?:// ]]; then
    echo "订阅链接必须以 http:// 或 https:// 开头."
    return 1
  fi

  load_subscription_urls
  for existing_url in "${SUBSCRIPTION_URLS[@]}"; do
    if [[ $existing_url == "$url" ]]; then
      echo "该订阅地址已经存在."
      return 1
    fi
  done

  append_subscription_url "$url" || {
    echo "保存订阅地址失败."
    return 1
  }
  echo "订阅地址已添加."

  read_line_or_back "是否立即激活并更新节点? (Y/n, Esc返回): "
  status=$?
  if (( status == 130 )); then return 130; fi
  if (( status != 0 )); then return 1; fi
  case "${INPUT_LINE,,}" in
    ""|y|yes) activate_subscription "$url" ;;
    n|no) echo "订阅已保存, 尚未激活." ;;
    *)
      echo "输入无效, 订阅已保存但尚未激活."
      return 1
      ;;
  esac
}

switch_managed_subscription() {
  local url

  select_subscription_url "选择要激活的订阅(Esc/0/回车返回): " || return
  url="$SELECTED"
  activate_subscription "$url"
}

snapshot_manager_runtime_state() {
  local snapshot_dir="$1"
  local name
  local path

  for name in active list region tun; do
    case "$name" in
      active) path="$SUBSCRIPTION_FILE" ;;
      list) path="$SUBSCRIPTION_LIST_FILE" ;;
      region) path="$REGION_STATE_FILE" ;;
      tun) path="$TUN_STATE_FILE" ;;
    esac
    if sudo test -f "$path"; then
      sudo install -m 600 "$path" "${snapshot_dir}/${name}" || return 1
    else
      touch "${snapshot_dir}/${name}.absent" || return 1
    fi
  done
  if [[ -f $PROXY_STATE_FILE ]]; then
    install -m 600 "$PROXY_STATE_FILE" "${snapshot_dir}/proxy" || return 1
  else
    touch "${snapshot_dir}/proxy.absent" || return 1
  fi
}

restore_manager_runtime_state() {
  local snapshot_dir="$1"
  local name
  local path

  for name in active list region tun; do
    case "$name" in
      active) path="$SUBSCRIPTION_FILE" ;;
      list) path="$SUBSCRIPTION_LIST_FILE" ;;
      region) path="$REGION_STATE_FILE" ;;
      tun) path="$TUN_STATE_FILE" ;;
    esac
    if sudo test -f "${snapshot_dir}/${name}"; then
      atomic_install_file 600 "${snapshot_dir}/${name}" "$path" || return 1
    else
      sudo rm -f -- "$path" || return 1
    fi
  done
  if sudo test -f "${snapshot_dir}/proxy"; then
    install -m 600 "${snapshot_dir}/proxy" "$PROXY_STATE_FILE" || return 1
  else
    rm -f -- "$PROXY_STATE_FILE" || return 1
  fi
  apply_proxy_state
  sync_tun_bypass_rules || true
}

delete_managed_subscription() {
  local url
  local active_url
  local temporary
  local mode="keep"
  local config_temporary
  local backup
  local state_snapshot
  local status

  select_subscription_url "选择要删除的订阅(Esc/0/回车返回): " || return
  url="$SELECTED"
  active_url="$(active_subscription_url)"

  echo "准备删除:"
  echo "$url"
  if [[ $url == "$active_url" ]]; then
    echo "这是当前激活订阅. 请选择删除后的节点处理方式:"
    echo "  1) 保留当前节点配置"
    echo "  2) 清理所有节点并恢复直连(同时关闭TUN和终端代理)"
    read_choice_or_back "输入编号(Esc/0返回): " || return 130
    case "$MENU_CHOICE" in
      1) mode="keep" ;;
      2) mode="clear" ;;
      *) echo "无效选项."; return 1 ;;
    esac
  fi
  read_line_or_back "确认删除? (y/N, Esc返回): "
  status=$?
  if (( status == 130 )); then return 130; fi
  if (( status != 0 )); then return 1; fi
  case "${INPUT_LINE,,}" in
    y|yes) ;;
    *)
      echo "已取消删除."
      return 130
      ;;
  esac

  temporary="$(mktemp /tmp/mihomo-subscriptions.XXXXXX)" || return
  # shellcheck disable=SC2024
  sudo awk -v target="$url" '$0 != target' "$SUBSCRIPTION_LIST_FILE" >"$temporary" || {
    rm -f -- "$temporary"
    return 1
  }
  if [[ $url == "$active_url" ]]; then
    state_snapshot="$(mktemp -d /tmp/mihomo-subscription-state.XXXXXX)" || {
      rm -f -- "$temporary"
      return 1
    }
    snapshot_manager_runtime_state "$state_snapshot" || {
      sudo rm -rf -- "$state_snapshot"
      rm -f -- "$temporary"
      return 1
    }
  fi
  if [[ $url == "$active_url" && $mode == clear ]]; then
    config_temporary="$(mktemp /tmp/mihomo-direct-config.XXXXXX.yaml)" || {
      sudo rm -rf -- "$state_snapshot"
      rm -f -- "$temporary"
      return 1
    }
    render_minimal_config "$config_temporary" || {
      sudo rm -rf -- "$state_snapshot"
      rm -f -- "$temporary" "$config_temporary"
      return 1
    }
    run_cancellable_named "正在验证无节点直连配置" 45 \
      sudo -n "$MIHOMO_BIN" -t -d "$CONFIG_DIR" -f "$config_temporary"
    status=$?
    if (( status != 0 )); then
      sudo rm -rf -- "$state_snapshot"
      rm -f -- "$temporary" "$config_temporary"
      (( status == 130 )) && return 130
      echo "直连配置验证失败, 原订阅和节点未改变."
      return 1
    fi

    backup="$(create_config_backup clear-subscription)" || {
      sudo rm -rf -- "$state_snapshot"
      rm -f -- "$temporary" "$config_temporary"
      return 1
    }
    atomic_install_file 600 "$config_temporary" "$CONFIG_FILE" || {
      rollback_config "$backup" || \
        echo "严重错误: 配置写入失败且自动恢复未完成, 请从 ${backup} 手动恢复."
      sudo rm -rf -- "$state_snapshot"
      rm -f -- "$temporary" "$config_temporary"
      return 1
    }
    if ! restart_mihomo_with_progress || ! wait_mihomo_with_progress 3; then
      if ! rollback_config "$backup" || ! wait_mihomo_with_progress 3; then
        echo "严重错误: 原配置自动恢复失败, 请从 ${backup} 手动恢复."
      fi
      restore_manager_runtime_state "$state_snapshot" || true
      sudo rm -rf -- "$state_snapshot"
      rm -f -- "$temporary" "$config_temporary"
      echo "清理节点后服务未能启动, 已尝试恢复原配置和订阅状态."
      return 1
    fi
    if ! atomic_install_file 600 "$temporary" "$SUBSCRIPTION_LIST_FILE" ||
       ! sudo rm -f -- "$SUBSCRIPTION_FILE" "$REGION_STATE_FILE" ||
       ! save_tun_state false ||
       ! write_proxy_state 0; then
      if restore_manager_runtime_state "$state_snapshot"; then
        sudo rm -rf -- "$state_snapshot"
      else
        echo "严重错误: 订阅和代理状态自动恢复失败, 快照保留在 ${state_snapshot}."
      fi
      if ! rollback_config "$backup" || ! wait_for_mihomo_stable 3; then
        echo "严重错误: 原配置自动恢复失败, 请从 ${backup} 手动恢复."
      fi
      rm -f -- "$temporary" "$config_temporary"
      echo "订阅状态提交失败, 已尝试恢复原节点配置和状态."
      return 1
    fi
    apply_proxy_state
    sync_tun_bypass_rules || true
    sudo rm -rf -- "$state_snapshot"
    rm -f -- "$temporary" "$config_temporary"
    refresh_api_config
    echo "当前订阅和所有代理节点已清理, 现在使用直连模式."
    echo "配置备份: ${backup}"
    return 0
  fi

  atomic_install_file 600 "$temporary" "$SUBSCRIPTION_LIST_FILE" || {
    [[ -n ${state_snapshot:-} ]] && sudo rm -rf -- "$state_snapshot"
    rm -f -- "$temporary"
    return 1
  }

  if [[ $url == "$active_url" ]]; then
    if ! sudo rm -f -- "$SUBSCRIPTION_FILE"; then
      if restore_manager_runtime_state "$state_snapshot"; then
        sudo rm -rf -- "$state_snapshot"
        echo "删除激活标记失败, 已恢复原订阅列表."
      else
        echo "严重错误: 原订阅状态恢复失败, 快照保留在 ${state_snapshot}."
      fi
      rm -f -- "$temporary"
      return 1
    fi
    sudo rm -rf -- "$state_snapshot"
    echo "当前激活订阅已清除. 现有节点配置保持不变."
  fi
  rm -f -- "$temporary"
  echo "订阅地址已删除."
}

manage_subscriptions() {
  local choice
  local status

  while true; do
    clear
    echo "================ 订阅管理 ================"
    show_subscription_urls
    cat <<'EOF'

 1) 新增订阅地址
 2) 切换订阅并更新对应节点
 3) 删除订阅地址
 4) 更新当前激活订阅
 0) 返回主菜单
============================================
EOF
    if ! read_choice_or_back "请选择(Esc/0返回): "; then
      return 130
    fi
    choice="$MENU_CHOICE"
    echo

    case "$choice" in
      1) add_managed_subscription; status=$? ;;
      2) switch_managed_subscription; status=$? ;;
      3) delete_managed_subscription; status=$? ;;
      4) refresh_subscription; status=$? ;;
      0) return 130 ;;
      *) echo "无效选项."; status=1 ;;
    esac

    if (( status != 130 )); then
      pause
    fi
  done
}

refresh_subscription() {
  local url

  if ! sudo test -s "$SUBSCRIPTION_FILE"; then
    echo "当前没有激活订阅, 请先使用选项2进入订阅管理并激活一个订阅."
    return 1
  fi

  url="$(sudo head -n 1 "$SUBSCRIPTION_FILE")"
  echo "正在更新当前激活订阅:"
  echo "$url"
  download_and_apply_subscription "$url"
}

render_minimal_config() {
  local output_file="$1"
  local secret=""
  local escaped_secret

  if sudo test -f "$CONFIG_FILE" 2>/dev/null; then
    secret="$(config_value secret 2>/dev/null || true)"
  fi
  if [[ -z $secret ]]; then
    secret="$(tr -d '-' </proc/sys/kernel/random/uuid 2>/dev/null || true)"
  fi
  [[ -n $secret ]] || secret="mipilot-$(date +%s)-$$"
  escaped_secret="${secret//\\/\\\\}"
  escaped_secret="${escaped_secret//\"/\\\"}"

  cat >"$output_file" <<EOF
mixed-port: 7890
allow-lan: false
bind-address: '127.0.0.1'
mode: direct
log-level: info
ipv6: false
external-controller: '127.0.0.1:9090'
secret: "${escaped_secret}"
tun:
  enable: false
  stack: mixed
  auto-route: true
  auto-detect-interface: true
proxies: []
proxy-groups: []
rules:
  - MATCH,DIRECT
EOF
}

service_exists() {
  sudo test -f "$SERVICE_FILE" 2>/dev/null || systemctl cat mihomo >/dev/null 2>&1
}

detect_install_state() {
  local binary_found=0
  local config_found=0
  local service_found=0
  local manager_found=0

  if [[ -x $MIHOMO_BIN ]] || command -v mihomo >/dev/null 2>&1; then binary_found=1; fi
  if sudo test -f "$CONFIG_FILE" 2>/dev/null; then config_found=1; fi
  if service_exists; then service_found=1; fi
  if sudo test -f "$MANAGER_INSTALLED_SCRIPT" 2>/dev/null && \
     sudo test -x "$MANAGER_COMMAND" 2>/dev/null && \
     sudo test -f "$CLEANUP_SERVICE_FILE" 2>/dev/null && \
     sudo test -f "$CLEANUP_TIMER_FILE" 2>/dev/null && \
     grep -Fq "$SHELL_INTEGRATION_BEGIN" "$SHELL_RC_FILE" 2>/dev/null; then
    manager_found=1
  fi

  if sudo test -f "$INSTALL_MARKER" 2>/dev/null; then
    if (( binary_found && config_found && service_found && manager_found )); then
      printf 'managed\n'
    else
      printf 'partial\n'
    fi
  elif (( binary_found && config_found && service_found )); then
    printf 'existing\n'
  elif (( binary_found || config_found || service_found || manager_found )); then
    printf 'partial\n'
  else
    printf 'absent\n'
  fi
}

check_supported_platform() {
  local os_id=""
  local version_id=""
  local major=0
  local architecture

  [[ -r /etc/os-release ]] || {
    echo "无法识别系统, 首版只支持 Ubuntu 20.04+ amd64."
    return 1
  }
  # shellcheck disable=SC1091
  source /etc/os-release
  os_id="${ID:-}"
  version_id="${VERSION_ID:-0}"
  major="${version_id%%.*}"
  architecture="$(uname -m)"
  if [[ $os_id != ubuntu || ! $major =~ ^[0-9]+$ || $major -lt 20 ]]; then
    echo "当前系统不受支持: ${os_id:-unknown} ${version_id}. 需要 Ubuntu 20.04+."
    return 1
  fi
  if [[ $architecture != x86_64 && $architecture != amd64 ]]; then
    echo "当前架构不受支持: ${architecture}. 首版仅支持 amd64."
    return 1
  fi
  if [[ ! -d /run/systemd/system ]]; then
    echo "当前系统未使用 systemd, 无法安装服务."
    return 1
  fi
}

missing_runtime_commands() {
  local command_name
  local missing=()

  for command_name in awk curl cut find flock gzip grep ip jq sed setsid sha256sum sort ss stat sudo systemctl timeout tr; do
    command -v "$command_name" >/dev/null 2>&1 || missing+=("$command_name")
  done
  printf '%s\n' "${missing[*]}"
}

ensure_install_dependencies() {
  local missing
  local status

  missing="$(missing_runtime_commands)"
  if [[ -z $missing ]] && dpkg-query -W -f='${Status}' ca-certificates 2>/dev/null | grep -Fq 'install ok installed'; then
    return 0
  fi

  echo "缺少首次安装依赖: ${missing:-ca-certificates}"
  read_line_or_back "是否通过 APT 安装依赖? (Y/n, Esc取消): "
  status=$?
  if (( status == 130 )); then return 130; fi
  if (( status != 0 )); then return 1; fi
  case "${INPUT_LINE,,}" in
    ""|y|yes) ;;
    *) echo "未安装依赖, 安装流程已停止."; return 1 ;;
  esac

  echo "正在更新软件源并安装依赖, 此过程可能需要几分钟..."
  sudo apt-get update || return 1
  sudo apt-get install -y ca-certificates coreutils curl findutils gzip iproute2 jq util-linux || return 1
  missing="$(missing_runtime_commands)"
  if [[ -n $missing ]]; then
    echo "依赖安装后仍缺少命令: ${missing}"
    return 1
  fi
}

LOCAL_MIHOMO_ARCHIVE=""
LOCAL_COUNTRY_MMDB=""
LOCAL_GEOSITE_DAT=""
STAGED_MIHOMO_BIN=""

find_local_assets() {
  local directory="${1:-$SCRIPT_DIR}"
  local candidate
  local candidates=()
  local sorted=()

  LOCAL_MIHOMO_ARCHIVE=""
  LOCAL_COUNTRY_MMDB=""
  LOCAL_GEOSITE_DAT=""
  [[ -d $directory ]] || return 1

  while IFS= read -r -d '' candidate; do
    if [[ $(basename -- "$candidate") =~ ^mihomo-linux-amd64-v[0-9]+\.[0-9]+\.[0-9]+\.gz$ ]]; then
      candidates+=("$candidate")
    fi
  done < <(find "$directory" -maxdepth 1 -type f -name 'mihomo-linux-amd64-v*.gz' -print0 2>/dev/null)
  if (( ${#candidates[@]} > 0 )); then
    mapfile -t sorted < <(printf '%s\n' "${candidates[@]}" | sort -V)
    LOCAL_MIHOMO_ARCHIVE="${sorted[$((${#sorted[@]} - 1))]}"
  fi

  for candidate in "$directory/country.mmdb" "$directory/Country.mmdb"; do
    if [[ -s $candidate ]]; then LOCAL_COUNTRY_MMDB="$candidate"; break; fi
  done
  for candidate in "$directory/geosite.dat" "$directory/GeoSite.dat"; do
    if [[ -s $candidate ]]; then LOCAL_GEOSITE_DAT="$candidate"; break; fi
  done

  [[ -n $LOCAL_MIHOMO_ARCHIVE && -n $LOCAL_COUNTRY_MMDB && -n $LOCAL_GEOSITE_DAT ]]
}

show_required_local_assets() {
  cat <<EOF
请把以下文件放到同一目录后重试:
  country.mmdb
  geosite.dat
  mihomo-linux-amd64-v<版本>.gz

官方地址:
  https://github.com/MetaCubeX/mihomo/releases/latest
  https://github.com/MetaCubeX/meta-rules-dat/releases/latest
EOF
}

validate_local_assets() {
  local validation_dir
  local validation_config

  [[ -s $LOCAL_MIHOMO_ARCHIVE && -s $LOCAL_COUNTRY_MMDB && -s $LOCAL_GEOSITE_DAT ]] || return 1
  gzip -t "$LOCAL_MIHOMO_ARCHIVE" || {
    echo "Mihomo 压缩包校验失败: ${LOCAL_MIHOMO_ARCHIVE}"
    return 1
  }
  STAGED_MIHOMO_BIN="$(mktemp /tmp/mipilot-core.XXXXXX)" || return 1
  gzip -dc "$LOCAL_MIHOMO_ARCHIVE" >"$STAGED_MIHOMO_BIN" || {
    rm -f -- "$STAGED_MIHOMO_BIN"
    STAGED_MIHOMO_BIN=""
    return 1
  }
  chmod 755 "$STAGED_MIHOMO_BIN"
  "$STAGED_MIHOMO_BIN" -v | grep -Fq 'Mihomo Meta' || {
    echo "压缩包中的程序不是有效的 Mihomo 内核."
    rm -f -- "$STAGED_MIHOMO_BIN"
    STAGED_MIHOMO_BIN=""
    return 1
  }

  validation_dir="$(mktemp -d /tmp/mipilot-validation.XXXXXX)" || return 1
  validation_config="${validation_dir}/config.yaml"
  install -m 644 "$LOCAL_COUNTRY_MMDB" "${validation_dir}/Country.mmdb"
  install -m 644 "$LOCAL_GEOSITE_DAT" "${validation_dir}/GeoSite.dat"
  cat >"$validation_config" <<'EOF'
mode: direct
log-level: silent
proxies: []
proxy-groups: []
rules:
  - GEOSITE,cn,DIRECT
  - GEOIP,cn,DIRECT,no-resolve
  - MATCH,DIRECT
EOF
  if ! "$STAGED_MIHOMO_BIN" -t -d "$validation_dir" -f "$validation_config"; then
    echo "Mihomo 或地理数据验证失败."
    rm -rf -- "$validation_dir"
    rm -f -- "$STAGED_MIHOMO_BIN"
    STAGED_MIHOMO_BIN=""
    return 1
  fi
  rm -rf -- "$validation_dir"
}

rollback_slot_path() {
  case "$1" in
    core|geo|service|manager) printf '%s/%s\n' "$ROLLBACK_DIR" "$1" ;;
    *) return 1 ;;
  esac
}

save_component_rollback() {
  local kind="$1"
  local slot
  local temporary

  slot="$(rollback_slot_path "$kind")" || return 1
  temporary="${slot}.new.$$"
  sudo rm -rf -- "$temporary"
  sudo install -d -m 700 "$temporary" || return 1
  case "$kind" in
    core)
      if sudo test -x "$MIHOMO_BIN"; then
        sudo install -m 755 "$MIHOMO_BIN" "${temporary}/mihomo" || {
          sudo rm -rf -- "$temporary"
          return 1
        }
      else
        sudo touch "${temporary}/absent" || return 1
      fi
      ;;
    geo)
      if sudo test -f "${CONFIG_DIR}/Country.mmdb"; then
        sudo install -m 644 "${CONFIG_DIR}/Country.mmdb" "${temporary}/Country.mmdb" || {
          sudo rm -rf -- "$temporary"
          return 1
        }
      else
        sudo touch "${temporary}/Country.mmdb.absent" || return 1
      fi
      if sudo test -f "${CONFIG_DIR}/GeoSite.dat"; then
        sudo install -m 644 "${CONFIG_DIR}/GeoSite.dat" "${temporary}/GeoSite.dat" || {
          sudo rm -rf -- "$temporary"
          return 1
        }
      else
        sudo touch "${temporary}/GeoSite.dat.absent" || return 1
      fi
      ;;
    service)
      if sudo test -f "$SERVICE_FILE"; then
        sudo install -m 644 "$SERVICE_FILE" "${temporary}/mihomo.service" || {
          sudo rm -rf -- "$temporary"
          return 1
        }
      else
        sudo touch "${temporary}/absent" || return 1
      fi
      ;;
    manager)
      if sudo test -f "$MANAGER_INSTALLED_SCRIPT"; then
        sudo install -m 755 "$MANAGER_INSTALLED_SCRIPT" "${temporary}/mipilot" || {
          sudo rm -rf -- "$temporary"
          return 1
        }
      else
        sudo touch "${temporary}/absent" || return 1
      fi
      if sudo test -f "$INSTALL_MARKER"; then
        sudo install -m 600 "$INSTALL_MARKER" "${temporary}/install-marker" || {
          sudo rm -rf -- "$temporary"
          return 1
        }
      else
        sudo touch "${temporary}/install-marker.absent" || return 1
      fi
      ;;
  esac
  printf '%s\n' "$(date +%s)" | sudo tee "${temporary}/created_at" >/dev/null || {
    sudo rm -rf -- "$temporary"
    return 1
  }
  sudo rm -rf -- "$slot" || return 1
  sudo mv -- "$temporary" "$slot" || return 1
}

restore_component_rollback() {
  local kind="$1"
  local slot

  slot="$(rollback_slot_path "$kind")" || return 1
  sudo test -d "$slot" || return 1
  case "$kind" in
    core)
      if sudo test -f "${slot}/absent"; then
        sudo rm -f -- "$MIHOMO_BIN"
      else
        atomic_install_file 755 "${slot}/mihomo" "$MIHOMO_BIN"
      fi
      ;;
    geo)
      if sudo test -f "${slot}/Country.mmdb"; then
        atomic_install_file 644 "${slot}/Country.mmdb" "${CONFIG_DIR}/Country.mmdb" || return 1
      else
        sudo rm -f -- "${CONFIG_DIR}/Country.mmdb" || return 1
      fi
      if sudo test -f "${slot}/GeoSite.dat"; then
        atomic_install_file 644 "${slot}/GeoSite.dat" "${CONFIG_DIR}/GeoSite.dat" || return 1
      else
        sudo rm -f -- "${CONFIG_DIR}/GeoSite.dat" || return 1
      fi
      ;;
    service)
      if sudo test -f "${slot}/absent"; then
        sudo rm -f -- "$SERVICE_FILE"
      else
        sudo install -m 644 "${slot}/mihomo.service" "$SERVICE_FILE"
      fi
      ;;
    manager)
      if sudo test -f "${slot}/absent"; then
        sudo rm -f -- "$MANAGER_INSTALLED_SCRIPT"
      else
        atomic_install_file 755 "${slot}/mipilot" "$MANAGER_INSTALLED_SCRIPT" || return 1
      fi
      if sudo test -f "${slot}/install-marker"; then
        atomic_install_file 600 "${slot}/install-marker" "$INSTALL_MARKER" || return 1
      elif sudo test -f "${slot}/install-marker.absent"; then
        sudo rm -f -- "$INSTALL_MARKER" || return 1
      fi
      ;;
  esac
}

cleanup_expired_rollbacks() {
  local now
  local slot
  local created

  sudo test -d "$ROLLBACK_DIR" || return 0
  now="$(date +%s)"
  for slot in core geo service manager; do
    if sudo test -f "${ROLLBACK_DIR}/${slot}/created_at"; then
      created="$(sudo cat "${ROLLBACK_DIR}/${slot}/created_at" 2>/dev/null || printf '0')"
      if [[ $created =~ ^[0-9]+$ ]] && (( now - created > ROLLBACK_MAX_AGE )); then
        sudo rm -rf -- "${ROLLBACK_DIR:?}/${slot}"
      fi
    fi
  done
}

write_service_unit() {
  local temporary

  temporary="$(mktemp /tmp/mipilot-service.XXXXXX)" || return 1
  cat >"$temporary" <<EOF
[Unit]
Description=Mihomo Proxy Service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=${MIHOMO_BIN} -d ${CONFIG_DIR}
Restart=on-failure
RestartSec=5s
LimitNOFILE=1048576
CapabilityBoundingSet=CAP_NET_ADMIN CAP_NET_RAW CAP_NET_BIND_SERVICE
AmbientCapabilities=CAP_NET_ADMIN CAP_NET_RAW CAP_NET_BIND_SERVICE
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
EOF
  sudo install -d -m 755 "$(dirname -- "$SERVICE_FILE")" || {
    rm -f -- "$temporary"
    return 1
  }
  atomic_install_file 644 "$temporary" "$SERVICE_FILE"
  local status=$?
  rm -f -- "$temporary"
  return "$status"
}

wait_for_mihomo_stable() {
  local checks="${1:-3}"
  local expected_version="${2:-}"
  local index
  local main_pid
  local running_executable
  local version_response
  local running_version

  for ((index = 0; index < checks; index++)); do
    sleep 1
    sudo -n systemctl is-active --quiet mihomo || return 1
  done
  main_pid="$(sudo -n systemctl show mihomo -p MainPID --value 2>/dev/null || true)"
  [[ $main_pid =~ ^[1-9][0-9]*$ ]] || return 1
  running_executable="$(sudo -n readlink -f "/proc/${main_pid}/exe" 2>/dev/null || true)"
  [[ $running_executable == "$(readlink -f -- "$MIHOMO_BIN")" ]] || return 1
  refresh_api_config
  if [[ -n $API ]]; then
    api_quick "${API}/configs" >/dev/null || return 1
  fi
  if [[ -n $expected_version ]]; then
    [[ -n $API ]] || return 1
    version_response="$(api_quick "${API}/version")" || return 1
    running_version="$(jq -r '.version // empty' <<<"$version_response")"
    [[ ${running_version#v} == "${expected_version#v}" ]] || return 1
  fi
}

