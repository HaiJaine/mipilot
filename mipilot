list_config_backups() {
  local backups=()
  local backup
  local index=1

  mapfile -t backups < <(
    sudo find "$BACKUP_DIR" -maxdepth 1 -type f -name 'config-*.yaml' -printf '%T@ %p\n' 2>/dev/null \
      | sort -nr \
      | cut -d' ' -f2-
  )
  if (( ${#backups[@]} == 0 )); then
    echo "暂无配置备份."
    return 0
  fi
  for backup in "${backups[@]}"; do
    printf ' %d) %s\n' "$index" "$(basename -- "$backup")"
    ((index++))
  done
}

restore_config_backup_menu() {
  local backups=()
