manual_rollback_manager() {
  local current
  local current_marker
  local restored_version
  local had_current_marker=0

  rollback_is_usable manager || {
    echo "没有可用的 MiPilot 管理器回退版本."
    return 1
  }
  current="$(mktemp /tmp/mipilot-current-manager.XXXXXX)" || return 1
  current_marker="$(mktemp /tmp/mipilot-current-marker.XXXXXX)" || {
    rm -f -- "$current"
    return 1
  }
  sudo install -m 755 "$MANAGER_INSTALLED_SCRIPT" "$current" || {
    rm -f -- "$current" "$current_marker"
    return 1
  }
  if sudo test -f "$INSTALL_MARKER"; then
    had_current_marker=1
    sudo install -m 600 "$INSTALL_MARKER" "$current_marker" || {
      rm -f -- "$current" "$current_marker"
      return 1
    }
  else
    : >"$current_marker"
  fi
  if ! restore_component_rollback manager || \
     ! sudo bash -n "$MANAGER_INSTALLED_SCRIPT"; then
    atomic_install_file 755 "$current" "$MANAGER_INSTALLED_SCRIPT" || true
    if (( had_current_marker == 1 )); then
      atomic_install_file 600 "$current_marker" "$INSTALL_MARKER" || true
    else
      sudo rm -f -- "$INSTALL_MARKER" || true
    fi
    rm -f -- "$current" "$current_marker"
    echo "管理器回退失败, 已尝试恢复回退前版本."
    return 1
  fi
  restored_version="$(sudo awk -F'"' '/^MANAGER_VERSION=/{print $2; exit}' "$MANAGER_INSTALLED_SCRIPT")"
  sudo rm -rf -- "${ROLLBACK_DIR:?}/manager"
  rm -f -- "$current" "$current_marker"
  echo "MiPilot 已回退到 ${restored_version:-上一版本}."
  echo "当前菜单仍是旧进程, 退出后请重新执行 mipilot."
  MANAGER_SHOULD_EXIT=1
}

