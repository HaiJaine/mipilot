download_latest_geo_files() {
  local output_dir="$1"
  local base="https://github.com/MetaCubeX/meta-rules-dat/releases/download/latest"
  local file

  for file in country.mmdb country.mmdb.sha256sum geosite.dat geosite.dat.sha256sum; do
