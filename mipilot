  }
  for backup in "${backups[@]}"; do labels+=("$(basename -- "$backup")"); done
  choose_item "选择要恢复的配置备份:" "${labels[@]}" || return 130
  for index in "${!labels[@]}"; do
    if [[ ${labels[$index]} == "$SELECTED" ]]; then selected_backup="${backups[$index]}"; break; fi
  done
  [[ -n $selected_backup ]] || return 1
  selected_copy="$(mktemp /tmp/mihomo-restore-config.XXXXXX.yaml)" || return 1
  sudo install -m 600 "$selected_backup" "$selected_copy" || return 1
  run_cancellable_named "正在验证备份配置" 45 \
    sudo -n "$MIHOMO_BIN" -t -d "$CONFIG_DIR" -f "$selected_copy" || {
    sudo rm -f -- "$selected_copy"
    echo "备份配置验证失败, 未执行恢复."
    return 1
