remove_managed_installation() {
  local remove_config="$1"

  if [[ $MANAGER_LIB_DIR != /usr/local/lib/mipilot ||
        $STATE_DIR != /var/lib/mipilot ||
        $MIHOMO_BIN != /usr/local/bin/mihomo ||
        $MANAGER_COMMAND != /usr/local/bin/mipilot ||
        $SERVICE_FILE != /etc/systemd/system/mihomo.service ||
        $CLEANUP_SERVICE_FILE != /etc/systemd/system/mipilot-cleanup.service ||
        $CLEANUP_TIMER_FILE != /etc/systemd/system/mipilot-cleanup.timer ||
        $TUN_BYPASS_SERVICE_FILE != /etc/systemd/system/mipilot-tun-bypass.service ||
        $PROXY_STATE_DIR != "${USER_HOME}/.config/mipilot" ]]; then
    echo "卸载路径不是标准受管路径, 为避免误删文件已中止."
    return 1
  fi
  if [[ $remove_config == 1 && $CONFIG_DIR != /etc/mihomo ]]; then
    echo "配置目录不是 /etc/mihomo, 为避免误删文件已中止."
    return 1
  fi

  write_proxy_state 0 || echo "警告: 无法写入终端代理关闭状态, 将直接清理当前Shell变量."
  unset http_proxy https_proxy all_proxy HTTP_PROXY HTTPS_PROXY ALL_PROXY no_proxy NO_PROXY
  export MIHOMO_PROXY_ENABLED=0
  if service_exists || systemctl is-active --quiet mihomo 2>/dev/null; then
    if ! run_blocking "正在停止并禁用 Mihomo 服务" 45 \
         sudo -n systemctl disable --now mihomo; then
      echo "无法停止 Mihomo 服务, 为避免残留运行进程, 已中止卸载."
      return 1
    fi
    if sudo systemctl is-active --quiet mihomo; then
      echo "Mihomo 服务仍在运行, 已中止卸载."
      return 1
    fi
  fi
  remove_all_tun_bypass_rules || echo "警告: 部分TUN公网服务保护规则未能删除."
  sudo systemctl disable --now "$(basename -- "$CLEANUP_TIMER_FILE")" >/dev/null 2>&1 || true
  sudo systemctl disable --now "$(basename -- "$TUN_BYPASS_SERVICE_FILE")" >/dev/null 2>&1 || true
  sudo rm -f -- "$SERVICE_FILE" "$CLEANUP_SERVICE_FILE" "$CLEANUP_TIMER_FILE" "$TUN_BYPASS_SERVICE_FILE" || return 1
  sudo systemctl daemon-reload || return 1
  sudo systemctl reset-failed mihomo >/dev/null 2>&1 || true
  sudo rm -f -- "$MIHOMO_BIN" "$MANAGER_COMMAND" || return 1

  if [[ $MANAGER_LIB_DIR == /usr/local/lib/mipilot ]]; then
    sudo rm -rf -- "$MANAGER_LIB_DIR" || return 1
  else
    echo "拒绝删除非标准管理器目录: ${MANAGER_LIB_DIR}"
    return 1
  fi
  if [[ $STATE_DIR == /var/lib/mipilot ]]; then
    sudo rm -rf -- "$STATE_DIR" || return 1
  else
    echo "拒绝删除非标准状态目录: ${STATE_DIR}"
    return 1
  fi
  if [[ $remove_config == 1 ]]; then
    if [[ $CONFIG_DIR == /etc/mihomo ]]; then
      sudo rm -rf -- "$CONFIG_DIR" || return 1
    else
      echo "拒绝删除非标准配置目录: ${CONFIG_DIR}"
      return 1
    fi
  fi
  remove_shell_integration || return 1
  if [[ $PROXY_STATE_DIR == "${USER_HOME}/.config/mipilot" ]]; then
    rm -rf -- "$PROXY_STATE_DIR" || return 1
  fi
  if [[ $LOCK_FILE == /run/lock/mipilot.lock ]]; then
    sudo rm -f -- "$LOCK_FILE" || true
  fi
  MANAGER_SHOULD_EXIT=1
  unset -f mipilot mihomoctl mihomo_menu 2>/dev/null || true
}

uninstall_menu() {
  local status

  echo "  1) 卸载程序和服务, 保留 /etc/mihomo 配置"
  echo "  2) 彻底卸载程序、服务、配置、订阅、备份和状态"
  read_choice_or_back "输入编号(Esc/0返回): " || return 130
  case "$MENU_CHOICE" in
    1)
      read_line_or_back "确认卸载并保留配置? (y/N): "
      status=$?
      if (( status != 0 )); then return "$status"; fi
      case "${INPUT_LINE,,}" in
        y|yes) remove_managed_installation 0 || { echo "卸载未完成, 请根据上方错误修复后重试."; return 1; } ;;
        *) echo "已取消卸载."; return 130 ;;
      esac
      ;;
    2)
      echo "警告: 此操作会删除 /etc/mihomo 中的全部配置和订阅."
      read_line_or_back "请输入 UNINSTALL 确认彻底卸载(Esc取消): "
      status=$?
      if (( status != 0 )); then return "$status"; fi
      if [[ $INPUT_LINE != UNINSTALL ]]; then
        echo "确认文字不匹配, 已取消卸载."
        return 130
      fi
      remove_managed_installation 1 || { echo "彻底卸载未完成, 请根据上方错误修复后重试."; return 1; }
      ;;
    *) echo "无效选项."; return 1 ;;
  esac
  echo "卸载完成. 用户保存的项目目录和离线包未删除."
  echo "系统共享的 curl、jq 等依赖未卸载."
}

test_and_restart() {
  local status

  ensure_sudo_access || return 1
  run_cancellable_named "正在验证 Mihomo 配置" 45 \
    sudo -n "$MIHOMO_BIN" -t -d "$CONFIG_DIR"
  status=$?
  if (( status == 130 )); then return 130; fi
  if (( status != 0 )); then
    echo "配置验证失败, 未重启服务."
    return 1
  fi

  if ! restart_mihomo_with_progress; then
    echo "服务重启失败."
    return 1
  fi
  wait_mihomo_with_progress 1 || return 1
  sudo systemctl status mihomo --no-pager -l
}

show_logs() {
  sudo journalctl -u mihomo -n 100 --no-pager
}

service_menu() {
  local choice

  while true; do
    (( MANAGER_SHOULD_EXIT == 1 )) && return 130
    clear
    echo "Mihomo 服务状态: $(systemctl is-active mihomo 2>/dev/null || true)"
    echo
    cat <<'EOF'
================ 服务维护 ================
 1) 验证配置并重启服务
 2) 启动/停止服务
 3) 查看最近 100 条日志
 4) 查看内核与数据版本
 5) 更新与版本回退
 6) 配置备份与恢复
 7) 生成脱敏诊断报告
 8) 修复或重新安装
 9) 卸载
 0) 返回主菜单
==========================================
EOF
    if ! read_choice_or_back "请选择(Esc/0返回): "; then
      return 130
    fi
    choice="$MENU_CHOICE"
    echo

    case "$choice" in
      1) run_action test_and_restart ;;
      2) run_action toggle_service_state ;;
      3) run_action show_logs ;;
      4) run_action show_component_status ;;
      5) update_menu ;;
      6) backup_menu ;;
      7) run_action run_blocking "正在生成脱敏诊断报告" 60 generate_diagnostic_report ;;
      8) run_action repair_installation_menu ;;
      9) run_action uninstall_menu ;;
      0) return 130 ;;
      *) echo "无效选项."; pause ;;
    esac
  done
}

check_dependencies() {
  local missing=()
  local command_name

  for command_name in awk curl cut find flock gzip grep ip jq sed setsid sha256sum sort ss stat sudo systemctl timeout tr; do
    if ! command -v "$command_name" >/dev/null 2>&1; then
      missing+=("$command_name")
    fi
  done

  if (( ${#missing[@]} > 0 )); then
    echo "缺少命令: ${missing[*]}"
    echo "请先安装缺失依赖."
    return 1
  fi

  if ! sudo test -f "$CONFIG_FILE"; then
    echo "找不到配置文件: ${CONFIG_FILE}"
    return 1
  fi

  if ! sudo test -x "$MIHOMO_BIN" && ! command -v mihomo >/dev/null 2>&1; then
    echo "找不到 Mihomo 内核: ${MIHOMO_BIN}"
    return 1
  fi
}

run_action() {
  local status

  "$@"
  status=$?
  if (( status != 130 )); then
    pause
  fi
}

main_menu() {
  local choice

  while true; do
    clear
    refresh_menu_runtime_summary
    echo "当前终端代理: $(proxy_status_label)"
    echo "TUN 模式: $(tun_status_label)"
    echo "当前运行策略: ${MENU_MODE_STATUS}"
    if [[ $MENU_RUNTIME_MODE == global ]]; then
      echo "当前全局节点: ${MENU_NODE_STATUS}"
    fi
    if (( SCRIPT_SOURCED == 0 )); then
      echo "提示: 当前以 ./脚本 方式运行, 代理开关无法修改退出菜单后的父终端."
      echo "请退出后执行: source ~/.bashrc, 然后使用 mipilot"
    fi
    echo
    cat <<'EOF'
================ MiPilot 代理管理器 =================
  1) 查看运行状态
  2) 管理订阅
  3) 节点管理
  4) 切换规则/全局/直连模式
EOF
    printf '  5) %s\n' "$(terminal_proxy_action_label)"
    printf '  6) %s\n' "$(tun_action_label)"
    cat <<'EOF'
  7) 服务维护
  0) 退出
=====================================================
EOF
    if ! read_choice_or_back "请选择(Esc/0退出): "; then
      break
    fi
    choice="$MENU_CHOICE"
    echo

    case "$choice" in
      1) run_action show_runtime_status ;;
      2) manage_subscriptions ;;
      3) run_action manage_nodes_by_mode ;;
      4) run_action switch_mode ;;
      5) run_action toggle_terminal_proxy ;;
      6) run_action toggle_tun_mode ;;
      7) service_menu; (( MANAGER_SHOULD_EXIT == 1 )) && break ;;
      0) break ;;
      *) echo "无效选项."; pause ;;
    esac
  done
}

main() {
  local status=0

  ensure_sudo_access || return 1
  acquire_manager_lock || return 1
  check_dependencies || { release_manager_lock; return 1; }
  ensure_subscription_list || { release_manager_lock; return 1; }
  ensure_shell_integration
  migrate_legacy_backups || true
  cleanup_expired_rollbacks || true
  if [[ $(tun_config_value) == true ]]; then
    run_blocking "正在刷新公网服务端口保护" 15 refresh_tun_bypass_ports || \
      echo "警告: 无法刷新公网服务端口保护列表."
    run_blocking "正在同步公网服务返回路由" 15 sync_tun_bypass_rules || \
      echo "警告: 无法同步公网服务返回流量保护规则."
  fi
  refresh_api_config
  sync_proxy_state
  main_menu || status=$?
  unset API_SECRET
  release_manager_lock
  return "$status"
}

entrypoint() {
  local action="${1:-}"
  local state

  case "$action" in
    --version|-v)
      echo "mipilot ${MANAGER_VERSION}"
      return 0
      ;;
    --cleanup)
      ensure_sudo_access || return 1
      acquire_manager_lock || return 1
      cleanup_expired_rollbacks
      local cleanup_status=$?
      release_manager_lock
      return "$cleanup_status"
      ;;
    --sync-bypass-rules)
      ensure_sudo_access || return 1
      sync_tun_bypass_rules
      return $?
      ;;
    --menu)
      main
      return $?
      ;;
    ""|--install) ;;
    *)
      echo "未知参数: ${action}"
      echo "用法: mipilot [--version|--cleanup|--sync-bypass-rules]"
      return 1
      ;;
  esac

  ensure_sudo_access || return 1
  state="$(detect_install_state)"
  if [[ $state == managed ]]; then
    if [[ $SCRIPT_PATH == "$MANAGER_INSTALLED_SCRIPT" ]]; then
      main
    else
      acquire_manager_lock || return 1
      offer_local_manager_upgrade
      local status=$?
      release_manager_lock
      (( status == 0 )) || return "$status"
      echo "Mihomo 已安装. 请执行:"
      echo "  source ~/.bashrc"
      echo "  mipilot"
    fi
  else
    check_supported_platform || return 1
    ensure_install_dependencies || return $?
    acquire_manager_lock || return 1
    run_install_wizard "$state"
    local status=$?
    release_manager_lock
    return "$status"
  fi
}

if [[ ${MIPILOT_TESTING:-0} != 1 ]]; then
  if [[ ${BASH_SOURCE[0]} == "$0" ]]; then
    entrypoint "$@"
  elif [[ ${1:-} == --menu ]]; then
    entrypoint --menu
  fi
fi
