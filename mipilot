pause() {
  local key

  echo
  printf '按 Enter 或 Esc 返回菜单...'
  while true; do
    if ! IFS= read -r -s -n 1 key; then
      echo
      return
    fi

    if [[ -z $key || $key == $'\e' ]]; then
      echo
      return
    fi
  done
}

ensure_sudo_access() {
  if (( EUID == 0 )); then
    return 0
  elif command -v sudo >/dev/null 2>&1; then
    sudo -v
  else
    echo "当前用户不是root且系统缺少sudo, 无法管理系统服务."
    return 1
  fi
}

read_choice_or_back() {
  local prompt="$1"
  local status

  MENU_CHOICE=""
  read_line_or_back "$prompt"
  status=$?
  if (( status == 130 )); then return 1; fi
  if (( status != 0 )); then return 1; fi

  MENU_CHOICE="$INPUT_LINE"

  if [[ -z $MENU_CHOICE || $MENU_CHOICE == 0 ]]; then
    return 1
  fi
}

read_line_or_back() {
  local prompt="$1"
  local character
  local line=""

  INPUT_LINE=""

  if [[ ! -t 0 || ! -t 1 ]]; then
    read -r -p "$prompt" line || return 1
    INPUT_LINE="$line"
    return 0
  fi

  printf '%s' "$prompt"
  while true; do
    if ! IFS= read -r -s -n 1 character; then
      echo
      return 1
    fi

    if [[ -z $character ]]; then
      echo
      INPUT_LINE="$line"
      return 0
    fi

    case "$character" in
      $'\e')
        echo
        return 130
        ;;
      $'\177'|$'\b')
        if [[ -n $line ]]; then
          line="${line%?}"
          printf '\b \b'
        fi
        ;;
      $'\025')
        while [[ -n $line ]]; do
          line="${line%?}"
          printf '\b \b'
        done
        ;;
      *)
        line+="$character"
        printf '%s' "$character"
        ;;
    esac
  done
}

run_with_progress() (
  local label="$1"
  local cancellable="$2"
  local timeout_seconds="$3"
  local temporary
  local process_id=0
  local key
  local status
  local loop_count=0
  local frame_index=0
  local progress_visible=0
  local timed_out=0
  local started_at=$SECONDS
  local elapsed=0
  local spinner_frames=('|' '/' '-' '\')

  shift 3
  set +m
  umask 077
  temporary="$(mktemp /tmp/mipilot-command.XXXXXX)" || return 1

  clear_progress() {
    if (( progress_visible == 1 )); then
      printf '\r\033[2K\033[?25h' >&2
      progress_visible=0
    fi
  }

  stop_progress_process() {
    (( process_id > 0 )) || return 0
    if kill -0 "$process_id" 2>/dev/null; then
      sudo -n kill -- "-${process_id}" 2>/dev/null || \
        kill -- "-${process_id}" 2>/dev/null || \
        kill "$process_id" 2>/dev/null || true
    fi
    wait "$process_id" 2>/dev/null || true
  }

  cleanup_progress() {
    clear_progress
    rm -f -- "$temporary"
  }

  trap 'stop_progress_process; cleanup_progress; exit 130' HUP INT TERM
  trap 'cleanup_progress' EXIT

  if [[ ! -t 2 ]]; then
    printf '%s...\n' "$label" >&2
  fi

  if declare -F "${1:-}" >/dev/null 2>&1; then
    "$@" >"$temporary" 2>&1 &
  else
    setsid "$@" >"$temporary" 2>&1 &
  fi
  process_id=$!

  while kill -0 "$process_id" 2>/dev/null; do
    ((loop_count++)) || true
    elapsed=$((SECONDS - started_at))
    if (( timeout_seconds > 0 && elapsed >= timeout_seconds )); then
      timed_out=1
      stop_progress_process
      break
    fi

    if (( loop_count >= 3 )) && [[ -t 2 ]]; then
      if (( progress_visible == 0 )); then
        printf '\033[?25l' >&2
      fi
      if [[ $cancellable == true ]]; then
        printf '\r\033[2K%s %s  已等待 %ss, 按 Esc 取消' \
          "$label" "${spinner_frames[$((frame_index % 4))]}" "$elapsed" >&2
      else
        printf '\r\033[2K%s %s  已等待 %ss, 当前阶段不可中断' \
          "$label" "${spinner_frames[$((frame_index % 4))]}" "$elapsed" >&2
      fi
      ((frame_index++)) || true
      progress_visible=1
    fi

    if [[ $cancellable == true && -t 0 ]]; then
      if IFS= read -r -s -n 1 -t 0.1 key && [[ $key == $'\e' ]]; then
        stop_progress_process
        clear_progress
        echo "已取消当前操作." >&2
        trap - EXIT HUP INT TERM
        cleanup_progress
        return 130
      fi
    else
      sleep 0.1
    fi
  done

  if (( timed_out == 1 )); then
    status=124
  else
    wait "$process_id"
    status=$?
  fi
  process_id=0
  clear_progress
  cat "$temporary"
  if (( timed_out == 1 )); then
    echo "${label}: 等待超过 ${timeout_seconds}s, 已停止." >&2
  elif [[ ! -t 2 ]]; then
    if (( status == 0 )); then
      echo "${label}: 完成." >&2
    else
      echo "${label}: 失败(状态 ${status})." >&2
    fi
  fi
  trap - EXIT HUP INT TERM
  cleanup_progress
  return "$status"
)

run_cancellable() {
  run_with_progress "处理中" true 0 "$@"
}

run_cancellable_named() {
  local label="$1"
  local timeout_seconds="$2"
  shift 2
  run_with_progress "$label" true "$timeout_seconds" "$@"
}

run_blocking() {
  local label="$1"
  local timeout_seconds="$2"
  shift 2
  run_with_progress "$label" false "$timeout_seconds" "$@"
}

ensure_shell_integration() {
  local bashrc="$SHELL_RC_FILE"
  local temporary

  mkdir -p "$PROXY_STATE_DIR"
  if [[ ! -f $PROXY_STATE_FILE && -f ${USER_HOME}/.config/mihomoctl/proxy-state.sh ]]; then
    cp -p -- "${USER_HOME}/.config/mihomoctl/proxy-state.sh" "$PROXY_STATE_FILE" || return 1
  elif [[ ! -f $PROXY_STATE_FILE && -f ${USER_HOME}/.config/mihomo-manager/proxy-state.sh ]]; then
    cp -p -- "${USER_HOME}/.config/mihomo-manager/proxy-state.sh" "$PROXY_STATE_FILE" || return 1
  fi
  touch "$bashrc"
  temporary="$(mktemp "${bashrc}.XXXXXX")" || return

  awk \
    -v block_begin="$SHELL_INTEGRATION_BEGIN" \
    -v block_end="$SHELL_INTEGRATION_END" \
    -v old_begin="$LEGACY_MIHOMOCTL_BEGIN" \
    -v old_end="$LEGACY_MIHOMOCTL_END" \
    -v legacy="$LEGACY_SHELL_INTEGRATION_MARKER" '
      $0 == block_begin || $0 == old_begin { skip = 1; next }
      skip && ($0 == block_end || $0 == old_end) { skip = 0; next }
      $0 == legacy { legacy_left = 6; next }
      legacy_left > 0 { legacy_left--; next }
      !skip { print }
    ' "$bashrc" >"$temporary" || {
      rm -f -- "$temporary"
      return 1
    }

  {
    cat "$temporary"
    printf '\n%s\n' "$SHELL_INTEGRATION_BEGIN"
    printf 'if [ -f "$HOME/.config/mipilot/proxy-state.sh" ]; then\n'
    printf '  . "$HOME/.config/mipilot/proxy-state.sh"\n'
    printf 'fi\n'
    printf 'mipilot() {\n'
    printf '  source "%s" --menu\n' "$MANAGER_INSTALLED_SCRIPT"
    printf '}\n'
    printf '%s\n' "$SHELL_INTEGRATION_END"
  } >"${temporary}.new"
  chmod --reference="$bashrc" "${temporary}.new" 2>/dev/null || chmod 600 "${temporary}.new"
  mv -f -- "${temporary}.new" "$bashrc"
  rm -f -- "$temporary"
}

remove_shell_integration() {
  local bashrc="$SHELL_RC_FILE"
  local temporary

  [[ -f $bashrc ]] || return 0
  temporary="$(mktemp "${bashrc}.XXXXXX")" || return
  awk \
    -v block_begin="$SHELL_INTEGRATION_BEGIN" \
    -v block_end="$SHELL_INTEGRATION_END" \
    -v old_begin="$LEGACY_MIHOMOCTL_BEGIN" \
    -v old_end="$LEGACY_MIHOMOCTL_END" \
    -v legacy="$LEGACY_SHELL_INTEGRATION_MARKER" '
      $0 == block_begin || $0 == old_begin { skip = 1; next }
      skip && ($0 == block_end || $0 == old_end) { skip = 0; next }
      $0 == legacy { legacy_left = 6; next }
      legacy_left > 0 { legacy_left--; next }
      !skip { print }
    ' "$bashrc" >"$temporary" || {
      rm -f -- "$temporary"
      return 1
    }
  chmod --reference="$bashrc" "$temporary" 2>/dev/null || true
  mv -f -- "$temporary" "$bashrc"
}

mipilot() {
  # shellcheck disable=SC1090
  source "$MANAGER_INSTALLED_SCRIPT" --menu
}

write_proxy_state() {
  local enabled="$1"
  local temporary

  mkdir -p "$PROXY_STATE_DIR"
  temporary="$(mktemp "${PROXY_STATE_FILE}.XXXXXX")" || return

  if [[ $enabled == 1 ]]; then
    {
      printf "export http_proxy='%s'\n" "$PROXY_URL"
      printf "export https_proxy='%s'\n" "$PROXY_URL"
      printf "export all_proxy='%s'\n" "$SOCKS_PROXY_URL"
      printf "export HTTP_PROXY='%s'\n" "$PROXY_URL"
      printf "export HTTPS_PROXY='%s'\n" "$PROXY_URL"
      printf "export ALL_PROXY='%s'\n" "$SOCKS_PROXY_URL"
      printf "export no_proxy='%s'\n" "$NO_PROXY_VALUE"
      printf "export NO_PROXY='%s'\n" "$NO_PROXY_VALUE"
      printf 'export MIHOMO_PROXY_ENABLED=1\n'
    } >"$temporary"
  else
    {
      printf 'unset http_proxy https_proxy all_proxy\n'
      printf 'unset HTTP_PROXY HTTPS_PROXY ALL_PROXY\n'
      printf 'unset no_proxy NO_PROXY\n'
      printf 'export MIHOMO_PROXY_ENABLED=0\n'
    } >"$temporary"
  fi

  chmod 600 "$temporary"
  mv -f -- "$temporary" "$PROXY_STATE_FILE"
}

apply_proxy_state() {
  if [[ -f $PROXY_STATE_FILE ]]; then
    # shellcheck disable=SC1090
    source "$PROXY_STATE_FILE"
  fi
}

sync_proxy_state() {
  apply_proxy_state
  if [[ ${MIHOMO_PROXY_ENABLED:-0} == 1 ]]; then
    write_proxy_state 1 || return
    apply_proxy_state
  fi
}

proxy_status_label() {
  if [[ ${http_proxy:-} == "$PROXY_URL" && ${https_proxy:-} == "$PROXY_URL" ]]; then
    printf '已开启并在当前终端生效, 已跳过局域网'
  elif [[ ${MIHOMO_PROXY_ENABLED:-0} == 1 ]]; then
    printf '已配置开启, 但当前终端尚未生效'
  elif [[ -n ${http_proxy:-} || -n ${https_proxy:-} || -n ${all_proxy:-} ]]; then
    printf '检测到其他代理环境变量'
  else
    printf '已关闭'
  fi
}

subscription_status_label() {
  local url
  local scheme
  local authority
  local host

  if ! sudo test -s "$SUBSCRIPTION_FILE"; then
    printf '未保存'
    return
  fi

  url="$(sudo head -n 1 "$SUBSCRIPTION_FILE")"
  scheme="${url%%:*}"
  authority="${url#*://}"
  host="${authority%%/*}"
  host="${host%%\?*}"

  if [[ -n $scheme && -n $host && $url == *://* ]]; then
    printf '已保存 (%s://%s/...)' "$scheme" "$host"
  else
    printf '已保存 (地址已隐藏)'
  fi
}

test_proxy_target() {
  local name="$1"
  local url="$2"
  local result

  echo "${name}: 测试中, 按 Esc 取消..."
  if result="$(
    run_cancellable_named "正在测试 ${name}" 22 curl \
      --proxy "$PROXY_URL" \
      --max-time 20 \
      -o /dev/null \
      -sS \
      -w 'HTTP=%{http_code} 连接=%{time_connect}s 总耗时=%{time_total}s' \
      "$url"
  )"; then
    echo "${name}: 成功, ${result}"
  else
    if (( $? == 130 )); then
      return 130
    fi
    [[ -n $result ]] && echo "$result"
    echo "${name}: 失败"
    return 1
  fi
}

show_proxy_environment() {
  echo "当前终端代理: $(proxy_status_label)"
  echo "  http_proxy=${http_proxy:-未设置}"
  echo "  https_proxy=${https_proxy:-未设置}"
  echo "  no_proxy=${no_proxy:-未设置}"
}

enable_system_proxy() {
  local status

  if ! systemctl is-active --quiet mihomo; then
    echo "Mihomo 服务未运行, 请先验证配置并启动服务."
    return 1
  fi

  write_proxy_state 1 || return
  apply_proxy_state

  echo "代理已开启."
  echo "HTTP/HTTPS: ${PROXY_URL}"
  echo "SOCKS5: ${SOCKS_PROXY_URL}"
  echo "已跳过: ${NO_PROXY_VALUE}"

  if (( SCRIPT_SOURCED == 0 )); then
    echo
    echo "提示: 当前是以子进程方式运行脚本, 无法修改父终端环境."
    echo "以后请使用 mipilot 启动菜单, 代理开关会立即作用于当前终端."
  fi

  echo
  echo "正在测试代理..."
  test_proxy_target "Google" "https://www.google.com/generate_204"
  status=$?
  if (( status == 130 )); then return 130; fi
  if (( status != 0 )); then
    echo "代理已开启, 但 Google 连通性失败, 请检查节点或规则."
  fi
}

disable_system_proxy() {
  write_proxy_state 0 || return
  apply_proxy_state
  echo "代理已关闭, 后续终端默认直连."

  if (( SCRIPT_SOURCED == 0 )); then
    echo "以后请使用 mipilot 启动菜单, 开关会立即作用于当前终端."
  fi
}

prune_config_backups() {
  local keep="${1:-$BACKUP_LIMIT}"
  local index
  local backups=()

  sudo test -d "$BACKUP_DIR" || return 0
  mapfile -t backups < <(
    sudo find "$BACKUP_DIR" -maxdepth 1 -type f -name 'config-*.yaml' -printf '%T@ %p\n' 2>/dev/null \
      | sort -nr \
      | cut -d' ' -f2-
  )
  for ((index = keep; index < ${#backups[@]}; index++)); do
    sudo rm -f -- "${backups[$index]}"
  done
}

create_config_backup() {
  local reason="${1:-manual}"
  local timestamp
  local backup

  sudo test -f "$CONFIG_FILE" || return 1
  reason="$(printf '%s' "$reason" | tr -cs 'A-Za-z0-9._-' '-')"
  timestamp="$(date +%Y%m%d-%H%M%S-%N)"
  backup="${BACKUP_DIR}/config-${timestamp}-${reason}.yaml"
  sudo install -d -m 700 "$BACKUP_DIR" || return 1
  sudo install -m 600 "$CONFIG_FILE" "$backup" || return 1
  prune_config_backups "$BACKUP_LIMIT" || return 1
  printf '%s\n' "$backup"
}

atomic_install_file() {
  local mode="$1"
  local source_file="$2"
  local destination="$3"
  local temporary="${destination}.new.$$.$RANDOM"

  sudo -n install -m "$mode" "$source_file" "$temporary" || {
    sudo -n rm -f -- "$temporary" 2>/dev/null || true
    return 1
  }
  sudo -n mv -f -- "$temporary" "$destination" || {
    sudo -n rm -f -- "$temporary" 2>/dev/null || true
    return 1
  }
}

migrate_legacy_backups() {
  local legacy
  local timestamp
  local target
  local index=0
  local legacy_files=()

  sudo install -d -m 700 "$BACKUP_DIR" || return 1
  mapfile -t legacy_files < <(
    sudo find "$CONFIG_DIR" -maxdepth 1 -type f -name 'config.yaml.bak*' -printf '%T@ %p\n' 2>/dev/null \
      | sort -nr \
      | cut -d' ' -f2-
  )
  for legacy in "${legacy_files[@]}"; do
    timestamp="$(sudo stat -c %Y "$legacy" 2>/dev/null || date +%s)"
    target="${BACKUP_DIR}/config-legacy-${timestamp}-${index}.yaml"
    if sudo install -m 600 "$legacy" "$target"; then
      sudo rm -f -- "$legacy"
    fi
    ((index++)) || true
  done
  prune_config_backups "$BACKUP_LIMIT"
}

tun_config_value() {
  if ! sudo test -f "$CONFIG_FILE" 2>/dev/null; then
    printf 'false\n'
    return 0
  fi
  sudo awk '
    /^tun:[[:space:]]*(#.*)?$/ {
      in_tun = 1
      next
    }
    in_tun && /^[^[:space:]#][^:]*:/ {
      exit
    }
    in_tun && /^[[:space:]]+enable:[[:space:]]*/ {
      value = $0
      sub(/^[[:space:]]+enable:[[:space:]]*/, "", value)
      sub(/[[:space:]]*#.*/, "", value)
      gsub(/[[:space:]]/, "", value)
      print tolower(value)
      found = 1
      exit
    }
    END {
      if (!found) print "false"
    }
  ' "$CONFIG_FILE"
}

tun_status_label() {
  case "$(tun_config_value)" in
    true) printf '已开启' ;;
    false) printf '已关闭' ;;
    *) printf '配置值异常' ;;
  esac
}

render_tun_config() {
  local input_file="$1"
  local output_file="$2"
  local enabled="$3"

  # The input needs sudo; the caller-owned output path intentionally does not.
  # shellcheck disable=SC2024
  sudo awk -v tun_enabled="$enabled" '
    function replace_boolean(line, key, value, indent, comment_pos, comment) {
      match(line, /^[[:space:]]*/)
      indent = substr(line, RSTART, RLENGTH)
      comment_pos = index(line, "#")
      comment = comment_pos ? " " substr(line, comment_pos) : ""
      return indent key ": " value comment
    }

    function finish_tun() {
      if (!enable_seen) print "  enable: " tun_enabled
      if (tun_enabled == "true") {
        if (!stack_seen) print "  stack: mixed"
        if (!auto_route_seen) print "  auto-route: true"
        if (!auto_redirect_seen) print "  auto-redirect: false"
        if (!auto_detect_seen) print "  auto-detect-interface: true"
        if (!dns_hijack_seen) {
          print "  dns-hijack:"
          print "    - any:53"
          print "    - tcp://any:53"
        }
      }
    }

    {
      if (in_tun && $0 ~ /^[^[:space:]#][^:]*:/) {
        finish_tun()
        in_tun = 0
      }

      if ($0 ~ /^tun:[[:space:]]*(#.*)?$/) {
        tun_found = 1
        in_tun = 1
        enable_seen = 0
        stack_seen = 0
        auto_route_seen = 0
        auto_redirect_seen = 0
        auto_detect_seen = 0
        dns_hijack_seen = 0
        print
        next
      }

      if ($0 ~ /^tun:[[:space:]]*[^[:space:]#]/) {
        print "不支持行内写法的 tun 配置, 请先改为多行 YAML." > "/dev/stderr"
        fatal = 1
        exit 42
      }

      if (in_tun) {
        if ($0 ~ /^[[:space:]]+enable:[[:space:]]*/) {
          print replace_boolean($0, "enable", tun_enabled)
          enable_seen = 1
          next
        }
        if ($0 ~ /^[[:space:]]+stack:[[:space:]]*/) stack_seen = 1
        if ($0 ~ /^[[:space:]]+dns-hijack:[[:space:]]*/) dns_hijack_seen = 1
        if ($0 ~ /^[[:space:]]+auto-route:[[:space:]]*/) {
          auto_route_seen = 1
          if (tun_enabled == "true") {
            print replace_boolean($0, "auto-route", "true")
            next
          }
        }
        if ($0 ~ /^[[:space:]]+auto-redirect:[[:space:]]*/) {
          auto_redirect_seen = 1
          if (tun_enabled == "true") {
            print replace_boolean($0, "auto-redirect", "false")
            next
          }
        }
        if ($0 ~ /^[[:space:]]+auto-detect-interface:[[:space:]]*/) {
          auto_detect_seen = 1
          if (tun_enabled == "true") {
            print replace_boolean($0, "auto-detect-interface", "true")
            next
          }
        }
        if ($0 ~ /^[[:space:]]+strict-route:[[:space:]]*/ && tun_enabled == "true") {
          print replace_boolean($0, "strict-route", "false")
          next
        }
      }

      print
    }

    END {
      if (fatal) exit 42
      if (in_tun) finish_tun()
      if (!tun_found) {
        print ""
        print "tun:"
        print "  enable: " tun_enabled
        print "  stack: mixed"
        print "  auto-route: true"
        print "  auto-redirect: false"
        print "  auto-detect-interface: true"
        print "  dns-hijack:"
        print "    - any:53"
        print "    - tcp://any:53"
      }
    }
  ' "$input_file" >"$output_file"
}

