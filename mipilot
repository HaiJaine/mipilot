detect_public_service_ports() {
  {
    if command -v ss >/dev/null 2>&1; then
      ss -H -ltn 2>/dev/null | awk '
        {
          address = $4
          if (address ~ /^0[.]0[.]0[.]0:/ || address ~ /^\*:/ || address ~ /^\[::\]:/) {
            sub(/^.*:/, "", address)
            if (address ~ /^[0-9]+$/) print "tcp:" address
          }
        }
      '
      ss -H -lun 2>/dev/null | awk '
        {
          address = $4
          if (address ~ /^0[.]0[.]0[.]0:/ || address ~ /^\*:/ || address ~ /^\[::\]:/) {
            sub(/^.*:/, "", address)
            if (address ~ /^[0-9]+$/) print "udp:" address
          }
        }
      '
    fi

    if command -v docker >/dev/null 2>&1 && timeout 4 sudo -n docker ps >/dev/null 2>&1; then
      timeout 4 sudo -n docker ps --format '{{.Ports}}' 2>/dev/null \
        | grep -oE '[0-9]+->[0-9]+/(tcp|udp)' \
        | sed -E 's/^([0-9]+)->[0-9]+\/(tcp|udp)$/\2:\1/' \
        || true
    fi
  } | awk -F: '
    ($1 == "tcp" || $1 == "udp") && $2 ~ /^[0-9]+$/ && $2 >= 1 && $2 <= 65535 {
      print $1 ":" $2
    }
  ' | sort -u
}

tun_bypass_rule_exists() {
  local protocol="$1"
  local port="$2"

  ip rule show 2>/dev/null \
    | grep -Fq "${TUN_BYPASS_RULE_PRIORITY}:" \
    && ip rule show 2>/dev/null \
      | grep -F "${TUN_BYPASS_RULE_PRIORITY}:" \
      | grep -Fq "ipproto ${protocol} sport ${port} lookup main"
}

add_tun_bypass_rule() {
  local protocol="$1"
  local port="$2"

  tun_bypass_rule_exists "$protocol" "$port" && return 0
  sudo -n ip rule add pref "$TUN_BYPASS_RULE_PRIORITY" \
    ipproto "$protocol" sport "$port" lookup main
}

delete_tun_bypass_rule() {
  local protocol="$1"
  local port="$2"

  while tun_bypass_rule_exists "$protocol" "$port"; do
    sudo -n ip rule del pref "$TUN_BYPASS_RULE_PRIORITY" \
      ipproto "$protocol" sport "$port" lookup main || return 1
  done
}

list_tun_bypass_ports() {
  sudo -n test -f "$TUN_BYPASS_STATE_FILE" || return 0
  sudo -n awk -F: '
    ($1 == "tcp" || $1 == "udp") && $2 ~ /^[0-9]+$/ && $2 >= 1 && $2 <= 65535 {
      print $1 ":" $2
    }
  ' "$TUN_BYPASS_STATE_FILE" | sort -u
}

refresh_tun_bypass_ports() {
  local temporary
  local protocol
  local port

  temporary="$(mktemp /tmp/mipilot-tun-bypass.XXXXXX)" || return 1
  detect_public_service_ports >"$temporary" || {
    rm -f -- "$temporary"
    return 1
  }

  while IFS=: read -r protocol port; do
    [[ -n $protocol && -n $port ]] || continue
    if ! grep -Fxq "${protocol}:${port}" "$temporary"; then
      delete_tun_bypass_rule "$protocol" "$port" || true
    fi
  done < <(list_tun_bypass_ports)

  atomic_install_file 600 "$temporary" "$TUN_BYPASS_STATE_FILE"
  local status=$?
  rm -f -- "$temporary"
  return "$status"
}

sync_tun_bypass_rules() {
  local enabled
  local protocol
  local port
  local failed=0

  enabled="$(tun_config_value)"
  while IFS=: read -r protocol port; do
    [[ -n $protocol && -n $port ]] || continue
    if [[ $enabled == true ]]; then
      add_tun_bypass_rule "$protocol" "$port" || failed=1
    else
      delete_tun_bypass_rule "$protocol" "$port" || failed=1
    fi
  done < <(list_tun_bypass_ports)
  return "$failed"
}

remove_all_tun_bypass_rules() {
  local protocol
  local port
  local failed=0

  while IFS=: read -r protocol port; do
    [[ -n $protocol && -n $port ]] || continue
    delete_tun_bypass_rule "$protocol" "$port" || failed=1
  done < <(list_tun_bypass_ports)
  return "$failed"
}

show_tun_bypass_ports() {
  local ports

  ports="$(list_tun_bypass_ports | paste -sd ',' - | sed 's/,/, /g')"
  if [[ -n $ports ]]; then
    echo "已保护公网服务返回端口: ${ports}"
  fi
}

apply_tun_setting() {
  local enabled="$1"
  local label="$2"
  local temporary
  local backup
  local status

  ensure_sudo_access || return 1
  temporary="$(mktemp /tmp/mihomo-tun-config.XXXXXX.yaml)" || return
  backup=""

  echo "[1/5] 正在生成 TUN 配置..."
  if ! render_tun_config "$CONFIG_FILE" "$temporary" "$enabled"; then
    rm -f -- "$temporary"
    echo "生成 TUN 配置失败, 现有配置未改变."
    return 1
  fi

  echo "[2/5] 验证配置"
  run_cancellable_named "正在验证 TUN 配置" 35 \
    sudo -n "$MIHOMO_BIN" -t -d "$CONFIG_DIR" -f "$temporary"
  status=$?
  if (( status == 130 )); then
    rm -f -- "$temporary"
    return 130
  fi
  if (( status != 0 )); then
    rm -f -- "$temporary"
    echo "配置验证失败, TUN 状态未改变."
    return 1
  fi

  echo "[3/5] 正在备份并替换配置, 此阶段不可中断..."
  backup="$(create_config_backup tun)" || {
    rm -f -- "$temporary"
    return 1
  }
  atomic_install_file 600 "$temporary" "$CONFIG_FILE" || {
    rm -f -- "$temporary"
    return 1
  }
  rm -f -- "$temporary"

  echo "[4/5] 重启 Mihomo 服务"
  if ! run_blocking "正在重启 Mihomo 服务" 35 sudo -n systemctl restart mihomo; then
    if rollback_config "$backup"; then
      echo "Mihomo 启动失败, TUN 状态已回滚."
    else
      echo "Mihomo 启动失败且自动回滚未完成, 请立即检查 ${backup}."
    fi
    return 1
  fi

  echo "[5/5] 等待 Mihomo 服务稳定"
  if ! run_blocking "正在等待 Mihomo 服务稳定" 15 wait_for_mihomo_stable 2; then
    if rollback_config "$backup"; then
      echo "Mihomo 未能稳定运行, TUN 状态已回滚."
    else
      echo "Mihomo 未稳定运行且自动回滚未完成, 请立即检查 ${backup}."
    fi
    return 1
  fi

  if ! save_tun_state "$enabled"; then
    echo "TUN 已${label}, 但持久化状态保存失败; 下次更新订阅后可能丢失该状态."
    return 1
  fi

  if [[ $enabled == true ]]; then
    if ! run_blocking "正在扫描并保存公网服务端口" 15 refresh_tun_bypass_ports; then
      echo "警告: 无法扫描公网服务端口, 请检查 iproute2 和 Docker 权限."
    fi
  fi
  if ! run_blocking "正在同步公网服务返回路由" 15 sync_tun_bypass_rules; then
    echo "警告: 公网服务返回流量保护规则同步失败."
  fi

  refresh_api_config
  echo "TUN 模式已${label}."
  [[ $enabled == true ]] && show_tun_bypass_ports
  echo "备份文件: ${backup}"
}

enable_tun_mode() {
  local status

  if [[ ! -c /dev/net/tun ]]; then
    echo "系统不存在 /dev/net/tun, 当前环境无法开启 TUN 模式."
    return 1
  fi

  echo "开启 TUN 会修改服务器路由和 DNS, 远程 SSH 连接可能受到影响."
  echo "当前终端代理: $(proxy_status_label)"

  if [[ ${MIHOMO_PROXY_ENABLED:-0} == 1 || -n ${http_proxy:-} || -n ${https_proxy:-} || -n ${all_proxy:-} || -n ${HTTP_PROXY:-} || -n ${HTTPS_PROXY:-} || -n ${ALL_PROXY:-} ]]; then
    read_line_or_back "检测到系统代理已开启, 是否先关闭? (Y/n, Esc返回): "
    status=$?
    if (( status == 130 )); then return 130; fi
    if (( status != 0 )); then return 1; fi
    case "${INPUT_LINE,,}" in
      ""|y|yes) disable_system_proxy || return ;;
      n|no) echo "将保留当前系统代理设置." ;;
      *)
        echo "输入无效, 请输入 y 或 n."
        return 1
        ;;
    esac
    echo
  fi

  read_line_or_back "确认开启 TUN? (y/N, Esc返回): "
  status=$?
  if (( status == 130 )); then return 130; fi
  if (( status != 0 )); then return 1; fi
  case "${INPUT_LINE,,}" in
    y|yes) ;;
    *)
      echo "已取消开启 TUN."
      return 130
      ;;
  esac

  apply_tun_setting true "开启"
}

disable_tun_mode() {
  local status

  read_line_or_back "确认关闭 TUN? (y/N, Esc返回): "
  status=$?
  if (( status == 130 )); then return 130; fi
  if (( status != 0 )); then return 1; fi
  case "${INPUT_LINE,,}" in
