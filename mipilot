config_has_group() {
  local config_file="$1"
  local group_name="$2"

  sudo awk -v target="$group_name" '
    function parse_group_name(text, value, quote) {
      value = text
      sub(/^[[:space:]]*-[[:space:]]*[{]?[[:space:]]*name[[:space:]]*:[[:space:]]*/, "", value)
      quote = substr(value, 1, 1)
      if (quote == "\"") {
        sub(/^"/, "", value)
        sub(/".*/, "", value)
      } else if (quote == "\047") {
        sub(/^\047/, "", value)
        sub(/\047.*/, "", value)
      } else {
        sub(/[[:space:]]*[,}#].*$/, "", value)
        sub(/[[:space:]]+$/, "", value)
      }
      return value
    }

    /^proxy-groups:[[:space:]]*$/ { in_groups = 1; next }
    in_groups && /^[^[:space:]#][^:]*:/ { exit }
    in_groups && /^[[:space:]]*-[[:space:]]*([{][[:space:]]*)?name[[:space:]]*:/ {
      if (parse_group_name($0) == target) {
        found = 1
        exit
      }
    }
    END { exit(found ? 0 : 1) }
  ' "$config_file"
}

parent_group_has_child() {
  local config_file="$1"
  local parent_name="$2"
  local child_name="$3"

  sudo awk -v parent="$parent_name" -v child="$child_name" '
    function parse_group_name(text, value, quote) {
      value = text
      sub(/^[[:space:]]*-[[:space:]]*[{]?[[:space:]]*name[[:space:]]*:[[:space:]]*/, "", value)
      quote = substr(value, 1, 1)
      if (quote == "\"") {
        sub(/^"/, "", value)
        sub(/".*/, "", value)
      } else if (quote == "\047") {
        sub(/^\047/, "", value)
        sub(/\047.*/, "", value)
      } else {
        sub(/[[:space:]]*[,}#].*$/, "", value)
        sub(/[[:space:]]+$/, "", value)
      }
      return value
    }

    /^proxy-groups:[[:space:]]*$/ { in_groups = 1; next }
    in_groups && /^[^[:space:]#][^:]*:/ { exit }
    in_groups && /^[[:space:]]*-[[:space:]]*([{][[:space:]]*)?name[[:space:]]*:/ {
      in_parent = parse_group_name($0) == parent
    }
    in_parent && index($0, child) {
      found = 1
      exit
    }
    END { exit(found ? 0 : 1) }
  ' "$config_file"
}

prepare_region_overlay() {
  local config_file="$1"
  local state_file="$2"
  local refs_file="$3"
  local definitions_file="$4"
  local code
  local name
  local pattern
  local exclude_pattern

  : >"$refs_file"
  : >"$definitions_file"
  exclude_pattern="$(region_exclude_pattern)"

  if ! config_has_group "$config_file" "🚀节点选择"; then
    echo "配置中找不到 🚀节点选择, 无法挂载自动地区组."
    return 1
  fi

  while IFS=';' read -r code name pattern; do
    [[ -z $code || -z $name || -z $pattern ]] && continue

    if ! config_has_group "$config_file" "$name"; then
      {
        printf '%s\n' "- name: \"${name}\""
        printf '%s\n' '  type: url-test'
        printf '%s\n' '  include-all-proxies: true'
        printf '%s\n' "  filter: \"(?i)(${pattern})\""
        printf '%s\n' "  exclude-filter: \"(?i)(${exclude_pattern})\""
        printf '%s\n' '  url: https://cp.cloudflare.com'
        printf '%s\n' '  interval: 300'
        printf '%s\n' '  tolerance: 50'
        printf '%s\n' '  lazy: true'
        printf '%s\n' '  empty-fallback: REJECT'
        printf '%s\n' '  expected-status: 200/204'
      } >>"$definitions_file"
    fi

    if ! parent_group_has_child "$config_file" "🚀节点选择" "$name"; then
      printf '%s\n' "$name" >>"$refs_file"
    fi
  done < <(sudo cat "$state_file")
}

refresh_saved_region_definitions() {
  local input_file="$1"
  local output_file="$2"
  local state_file="$3"
  local exclude_pattern

  exclude_pattern="$(region_exclude_pattern)"
  # The input needs sudo; the caller-owned output path intentionally does not.
  # shellcheck disable=SC2024
  sudo awk \
    -v state_file="$state_file" \
    -v exclude_pattern="$exclude_pattern" '
      function parse_group_name(text, value, quote) {
        value = text
        sub(/^[[:space:]]*-[[:space:]]*[{]?[[:space:]]*name[[:space:]]*:[[:space:]]*/, "", value)
        quote = substr(value, 1, 1)
        if (quote == "\"") {
          sub(/^"/, "", value)
          sub(/".*/, "", value)
        } else if (quote == "\047") {
          sub(/^\047/, "", value)
          sub(/\047.*/, "", value)
        } else {
          sub(/[[:space:]]*[,}#].*$/, "", value)
          sub(/[[:space:]]+$/, "", value)
        }
        return value
      }

      function finish_managed_group() {
        if (!managed) return
        if (!filter_written) {
          print field_indent "filter: \"(?i)(" patterns[current_group] ")\""
        }
        if (!exclude_written) {
          print field_indent "exclude-filter: \"(?i)(" exclude_pattern ")\""
        }
        managed = 0
      }

      BEGIN {
        while ((getline record < state_file) > 0) {
          field_count = split(record, fields, ";")
          if (field_count >= 3 && fields[2] != "" && fields[3] != "") {
            patterns[fields[2]] = fields[3]
          }
        }
        close(state_file)
      }

      {
        line = $0

        if (in_groups && line ~ /^[^[:space:]#][^:]*:/) {
          finish_managed_group()
          in_groups = 0
        }

        if (line ~ /^proxy-groups:[[:space:]]*$/) {
          in_groups = 1
          print line
          next
        }

        if (in_groups && line ~ /^[[:space:]]*-[[:space:]]*([{][[:space:]]*)?name[[:space:]]*:/) {
          finish_managed_group()
          current_group = parse_group_name(line)
          managed = current_group in patterns
          filter_written = 0
          exclude_written = 0
          match(line, /^[[:space:]]*/)
          field_indent = substr(line, RSTART, RLENGTH) "  "
          if (managed && line ~ /[}][[:space:]]*$/) unsupported = 1
          print line
          next
        }

        if (managed && line ~ /^[[:space:]]+filter[[:space:]]*:/) {
          print field_indent "filter: \"(?i)(" patterns[current_group] ")\""
          filter_written = 1
          next
        }

        if (managed && line ~ /^[[:space:]]+exclude-filter[[:space:]]*:/) {
          print field_indent "exclude-filter: \"(?i)(" exclude_pattern ")\""
          exclude_written = 1
          next
        }

        print line
      }

      END {
        finish_managed_group()
        if (unsupported) {
          print "已保存的地区组使用不支持的单行定义, 未修改文件." > "/dev/stderr"
          exit 42
        }
      }
    ' "$input_file" >"$output_file"
}

region_group_rules_current() {
  local config_file="$1"
  local state_file="$2"
  local exclude_pattern

  exclude_pattern="$(region_exclude_pattern)"
  # The input needs sudo; the caller-owned output path intentionally does not.
  # shellcheck disable=SC2024
  sudo awk \
    -v state_file="$state_file" \
    -v exclude_pattern="$exclude_pattern" '
      function parse_group_name(text, value, quote) {
        value = text
        sub(/^[[:space:]]*-[[:space:]]*[{]?[[:space:]]*name[[:space:]]*:[[:space:]]*/, "", value)
        quote = substr(value, 1, 1)
        if (quote == "\"") {
          sub(/^"/, "", value)
          sub(/".*/, "", value)
        } else if (quote == "\047") {
          sub(/^\047/, "", value)
          sub(/\047.*/, "", value)
        } else {
          sub(/[[:space:]]*[,}#].*$/, "", value)
          sub(/[[:space:]]+$/, "", value)
        }
        return value
      }

      function finish_managed_group() {
        if (!managed) return
        seen[current_group] = 1
        if (!filter_ok || !exclude_ok) invalid = 1
        managed = 0
      }

      BEGIN {
        while ((getline record < state_file) > 0) {
          field_count = split(record, fields, ";")
          if (field_count >= 3 && fields[2] != "" && fields[3] != "") {
            patterns[fields[2]] = fields[3]
            expected++
          }
        }
        close(state_file)
      }

      /^proxy-groups:[[:space:]]*$/ { in_groups = 1; next }
      in_groups && /^[^[:space:]#][^:]*:/ {
        finish_managed_group()
        in_groups = 0
      }
      in_groups && /^[[:space:]]*-[[:space:]]*([{][[:space:]]*)?name[[:space:]]*:/ {
        finish_managed_group()
        current_group = parse_group_name($0)
        managed = current_group in patterns
        filter_ok = 0
        exclude_ok = 0
        next
      }
      managed && /^[[:space:]]+filter[[:space:]]*:/ {
        desired = "filter: \"(?i)(" patterns[current_group] ")\""
        if (index($0, desired)) filter_ok = 1
      }
      managed && /^[[:space:]]+exclude-filter[[:space:]]*:/ {
        desired = "exclude-filter: \"(?i)(" exclude_pattern ")\""
        if (index($0, desired)) exclude_ok = 1
      }

      END {
        finish_managed_group()
        for (name in patterns) {
          if (!(name in seen)) invalid = 1
        }
        exit(invalid ? 1 : 0)
      }
    ' "$config_file"
}

render_region_overlay() {
  local input_file="$1"
  local output_file="$2"
  local refs_file="$3"
  local definitions_file="$4"

  # The input needs sudo; the caller-owned output path intentionally does not.
  # shellcheck disable=SC2024
  sudo awk \
    -v refs_file="$refs_file" \
    -v definitions_file="$definitions_file" \
    -v parent_name="🚀节点选择" '
      function parse_group_name(text, value, quote) {
        value = text
        sub(/^[[:space:]]*-[[:space:]]*[{]?[[:space:]]*name[[:space:]]*:[[:space:]]*/, "", value)
        quote = substr(value, 1, 1)
        if (quote == "\"") {
          sub(/^"/, "", value)
          sub(/".*/, "", value)
        } else if (quote == "\047") {
          sub(/^\047/, "", value)
          sub(/\047.*/, "", value)
        } else {
          sub(/[[:space:]]*[,}#].*$/, "", value)
          sub(/[[:space:]]+$/, "", value)
        }
        return value
      }

      function append_definitions(line) {
        if (definitions_added) return
        if (group_indent == "") group_indent = "  "
        while ((getline line < definitions_file) > 0) {
          print group_indent line
        }
        close(definitions_file)
        definitions_added = 1
      }

      function append_block_refs(indent, i) {
        for (i = 1; i <= ref_count; i++) {
          print indent "- \"" refs[i] "\""
        }
        refs_inserted = 1
      }

      function add_inline_refs(line, segment, addition, separator, end_pos, i) {
        if (!match(line, /proxies:[[:space:]]*\[[^]]*/)) return ""
        segment = substr(line, RSTART, RLENGTH)
        separator = segment ~ /\[[[:space:]]*$/ ? "" : ", "
        addition = ""
        for (i = 1; i <= ref_count; i++) {
          addition = addition separator "\"" refs[i] "\""
          separator = ", "
        }
        end_pos = RSTART + RLENGTH
        refs_inserted = 1
        return substr(line, 1, end_pos - 1) addition substr(line, end_pos)
      }

      BEGIN {
        while ((getline ref < refs_file) > 0) {
          if (ref != "") refs[++ref_count] = ref
        }
        close(refs_file)
        if (ref_count == 0) refs_inserted = 1
      }

      {
        line = $0

        if (in_groups && line ~ /^[^[:space:]#][^:]*:/) {
          append_definitions()
          in_groups = 0
          in_parent = 0
        }

        if (line ~ /^proxy-groups:[[:space:]]*$/) {
          groups_found = 1
          in_groups = 1
          print line
          next
        }

        if (in_groups && group_indent == "" && line ~ /^[[:space:]]*-[[:space:]]/) {
          match(line, /^[[:space:]]*/)
          group_indent = substr(line, RSTART, RLENGTH)
        }

        if (in_groups && line ~ /^[[:space:]]*-[[:space:]]*([{][[:space:]]*)?name[[:space:]]*:/) {
          in_parent = parse_group_name(line) == parent_name
        }

        if (in_parent && line ~ /proxies:[[:space:]]*\[/ && ref_count > 0) {
          changed = add_inline_refs(line)
          if (changed == "") {
            fatal = 1
            exit 42
          }
          print changed
          next
        }

        if (in_parent && line ~ /^[[:space:]]+proxies:[[:space:]]*$/ && ref_count > 0) {
          print line
          match(line, /^[[:space:]]*/)
          append_block_refs(substr(line, RSTART, RLENGTH) "  ")
          next
        }

        print line
      }

      END {
        if (fatal) exit 42
        if (in_groups) append_definitions()
        if (!groups_found) {
          print "找不到块状 proxy-groups 配置, 未修改文件." > "/dev/stderr"
          exit 42
        }
        if (!refs_inserted) {
          print "找不到 🚀节点选择 的 proxies 列表, 未修改文件." > "/dev/stderr"
          exit 42
        }
      }
    ' "$input_file" >"$output_file"
}

apply_region_groups_to_config() {
  local input_file="$1"
  local output_file="$2"
  local state_file="$3"
  local refs_file
  local definitions_file
  local refreshed_file
  local status

  refs_file="$(mktemp /tmp/mihomo-region-refs.XXXXXX)" || return
  definitions_file="$(mktemp /tmp/mihomo-region-definitions.XXXXXX)" || {
    rm -f -- "$refs_file"
    return 1
  }
  refreshed_file="$(mktemp /tmp/mihomo-region-refreshed.XXXXXX.yaml)" || {
    rm -f -- "$refs_file" "$definitions_file"
    return 1
  }

  refresh_saved_region_definitions "$input_file" "$refreshed_file" "$state_file"
  status=$?
  if (( status == 0 )); then
    prepare_region_overlay "$refreshed_file" "$state_file" "$refs_file" "$definitions_file"
    status=$?
  fi
  if (( status == 0 )); then
    render_region_overlay "$refreshed_file" "$output_file" "$refs_file" "$definitions_file"
    status=$?
  fi

  rm -f -- "$refs_file" "$definitions_file" "$refreshed_file"
  return "$status"
}

auto_add_region_groups() {
  local response="$1"
  local nodes_file
  local groups_file
  local existing_state
  local candidate_state
  local dedup_state
  local temporary_config
  local backup
  local code
  local name
  local pattern
  local old_line
  local count
  local status
  local needs_apply=0
  local added_count=0
  local rules_need_refresh=0

  nodes_file="$(mktemp /tmp/mihomo-region-nodes.XXXXXX)" || return
  groups_file="$(mktemp /tmp/mihomo-region-groups.XXXXXX)" || {
    rm -f -- "$nodes_file"
    return 1
  }
  existing_state="$(mktemp /tmp/mihomo-region-existing.XXXXXX)" || {
    rm -f -- "$nodes_file" "$groups_file"
    return 1
  }
  candidate_state="$(mktemp /tmp/mihomo-region-state.XXXXXX)" || {
    rm -f -- "$nodes_file" "$groups_file" "$existing_state"
    return 1
  }
  dedup_state="$(mktemp /tmp/mihomo-region-state-dedup.XXXXXX)" || {
    rm -f -- "$nodes_file" "$groups_file" "$existing_state" "$candidate_state"
    return 1
  }
  temporary_config="$(mktemp /tmp/mihomo-region-config.XXXXXX.yaml)" || {
    rm -f -- "$nodes_file" "$groups_file" "$existing_state" "$candidate_state" "$dedup_state"
    return 1
  }
  backup=""

  jq -r '
    .proxies
    | to_entries[]
    | select(.value.all == null)
    | select(.key != "DIRECT" and .key != "REJECT" and .key != "PASS")
    | select(
        (.value.type // "") != "Direct"
        and (.value.type // "") != "Reject"
        and (.value.type // "") != "Pass"
        and (.value.type // "") != "Compatible"
        and (.value.type // "") != "DNS"
      )
    | select(
        .key
        | test("剩余流量|流量剩余|到期时间|过期时间|套餐到期|重置时间|流量重置|Traffic|Expire|Expiration|Bandwidth|Reset"; "i")
        | not
      )
    | .key
  ' <<<"$response" >"$nodes_file"
  jq -r '.proxies | to_entries[] | select(.value.all != null) | .key' <<<"$response" >"$groups_file"

  if sudo test -s "$REGION_STATE_FILE"; then
    # shellcheck disable=SC2024
    sudo cat "$REGION_STATE_FILE" >"$existing_state" || {
      rm -f -- "$nodes_file" "$groups_file" "$existing_state" "$candidate_state" "$dedup_state" "$temporary_config"
      return 1
    }
  fi

  echo "正在扫描订阅中的实际节点..."
  echo
  echo "扫描结果:"
  while IFS=';' read -r code name pattern; do
    [[ -z $code || -z $name || -z $pattern ]] && continue

    old_line="$(awk -F';' -v target="$code" '$1 == target { print; exit }' "$existing_state")"
    if [[ -n $old_line ]]; then
      printf '%s;%s;%s\n' "$code" "$name" "$pattern" >>"$candidate_state"
      continue
    fi

    if grep -Eiq -- "$pattern" "$groups_file"; then
      continue
    fi

    count="$(grep -Eic -- "$pattern" "$nodes_file" || true)"
    if (( count == 0 )); then
      continue
    fi

    printf '  新增 %s: %s 个节点\n' "$name" "$count"
    needs_apply=1
    added_count=$((added_count + 1))
    printf '%s;%s;%s\n' "$code" "$name" "$pattern" >>"$candidate_state"
  done < <(region_specs)

  awk -F';' 'NF >= 3 && !seen[$1]++' "$candidate_state" >"$dedup_state"
  if [[ -s $dedup_state ]] && ! region_group_rules_current "$CONFIG_FILE" "$dedup_state"; then
    rules_need_refresh=1
    needs_apply=1
    echo "  修正已有自动地区组的筛选规则."
  fi

  if (( needs_apply == 0 )); then
    echo "  地区组已完整, 筛选规则无需更新."
    rm -f -- "$nodes_file" "$groups_file" "$existing_state" "$candidate_state" "$dedup_state" "$temporary_config"
    return 0
  fi

  echo
  if (( added_count > 0 )); then
    echo "新增地区组将使用 URLTest 自动测速, 并加入 🚀节点选择."
  fi
  if (( rules_need_refresh > 0 )); then
    echo "已有自动地区组将更新匹配规则并排除流量、到期等提示节点."
  fi
  read_line_or_back "确认生成并应用? (y/N, Esc返回): "
  status=$?
  if (( status == 130 )); then
    rm -f -- "$nodes_file" "$groups_file" "$existing_state" "$candidate_state" "$dedup_state" "$temporary_config"
    return 130
  fi
  if (( status != 0 )); then
    rm -f -- "$nodes_file" "$groups_file" "$existing_state" "$candidate_state" "$dedup_state" "$temporary_config"
    return 1
  fi
  case "${INPUT_LINE,,}" in
    y|yes) ;;
    *)
      echo "已取消, 配置未改变."
      rm -f -- "$nodes_file" "$groups_file" "$existing_state" "$candidate_state" "$dedup_state" "$temporary_config"
      return 130
      ;;
  esac

  echo "正在生成地区策略组配置..."
  if ! apply_region_groups_to_config "$CONFIG_FILE" "$temporary_config" "$dedup_state"; then
    echo "无法安全合并地区策略组, 现有配置未改变."
    rm -f -- "$nodes_file" "$groups_file" "$existing_state" "$candidate_state" "$dedup_state" "$temporary_config"
    return 1
  fi

  run_cancellable_named "正在验证地区策略组配置" 45 \
    sudo -n "$MIHOMO_BIN" -t -d "$CONFIG_DIR" -f "$temporary_config"
  status=$?
  if (( status == 130 )); then
    rm -f -- "$nodes_file" "$groups_file" "$existing_state" "$candidate_state" "$dedup_state" "$temporary_config"
    return 130
  fi
  if (( status != 0 )); then
    echo "地区策略组配置验证失败, 现有配置未改变."
    rm -f -- "$nodes_file" "$groups_file" "$existing_state" "$candidate_state" "$dedup_state" "$temporary_config"
    return 1
  fi

  echo "配置验证成功, 正在备份、替换并重启服务; 此阶段不可中断."
  backup="$(create_config_backup region)" || {
    rm -f -- "$nodes_file" "$groups_file" "$existing_state" "$candidate_state" "$dedup_state" "$temporary_config"
    return 1
  }
  atomic_install_file 600 "$temporary_config" "$CONFIG_FILE" || {
    rm -f -- "$nodes_file" "$groups_file" "$existing_state" "$candidate_state" "$dedup_state" "$temporary_config"
    return 1
  }

  if ! restart_mihomo_with_progress; then
    if rollback_config "$backup"; then
      echo "新配置启动失败, 已自动回滚."
    else
      echo "新配置启动失败且自动回滚未完成, 请立即检查 ${backup}."
    fi
    rm -f -- "$nodes_file" "$groups_file" "$existing_state" "$candidate_state" "$dedup_state" "$temporary_config"
    return 1
  fi

  if ! wait_mihomo_with_progress 2; then
    if rollback_config "$backup"; then
      echo "新配置未能稳定运行, 已自动回滚."
    else
      echo "新配置未稳定运行且自动回滚未完成, 请立即检查 ${backup}."
    fi
    rm -f -- "$nodes_file" "$groups_file" "$existing_state" "$candidate_state" "$dedup_state" "$temporary_config"
    return 1
  fi

  if ! atomic_install_file 600 "$dedup_state" "$REGION_STATE_FILE"; then
    echo "地区组已经生效, 但持久化状态保存失败; 更新订阅后可能丢失."
    rm -f -- "$nodes_file" "$groups_file" "$existing_state" "$candidate_state" "$dedup_state" "$temporary_config"
    return 1
  fi

  rm -f -- "$nodes_file" "$groups_file" "$existing_state" "$candidate_state" "$dedup_state" "$temporary_config"
  refresh_api_config
  echo "地区策略组及筛选规则已更新."
  echo "备份文件: ${backup}"
}

manage_rule_nodes() {
  local response
  local record
  local group
  local selected_label
  local index
  local groups=()
  local display_groups=()

  response="$(api "${API}/proxies")" || return
  mapfile -t groups < <(
    jq -r '
      .proxies
      | to_entries
      | map(select(.value.type == "Selector" and .key != "GLOBAL"))
      | sort_by(.key)
      | .[]
      | .key
    ' <<<"$response"
  )

  if (( ${#groups[@]} == 0 )); then
    echo "当前配置中没有可手动切换的 rule 策略组."
    return 1
  fi

  for group in "${groups[@]}"; do
    record="$(jq -r --arg group "$group" '.proxies[$group].now // "未选择"' <<<"$response")"
    display_groups+=("${group} [当前: ${record}]")
  done
  groups+=("__AUTO_REGION_GROUPS__")
  display_groups+=("【管理功能】自动扫描并补充地区策略组")

  choose_item "选择要管理的策略组:" "${display_groups[@]}" || return
  selected_label="$SELECTED"
  group=""
  for index in "${!display_groups[@]}"; do
    if [[ ${display_groups[$index]} == "$selected_label" ]]; then
      group="${groups[$index]}"
      break
    fi
  done

  if [[ -z $group ]]; then
    echo "无法识别策略组选择结果."
    return 1
  fi

  if [[ $group == "__AUTO_REGION_GROUPS__" ]]; then
    auto_add_region_groups "$response"
    return $?
  fi

  manage_selector_group "$group" "$response"
}

manage_selector_group() {
  local group="$1"
  local all_response="$2"
  local response
  local group_url
  local node
  local type
  local type_label
  local child_current
  local description
  local has_children
  local data
  local current
  local delay_response
  local delay
  local marker
  local choice
  local option_number=1
  local status
  local actual_nodes_json='[]'
  local strategy_nodes=()
  local actual_nodes=()
  local special_nodes=()
  local ordered_strategy_nodes=()
  local selectable_nodes=()

  group_url="$(urlencode "$group")"

  response="$(api "${API}/proxies/${group_url}")" || return
  current="$(jq -r '.now // ""' <<<"$response")"
  echo "正在测试 ${group} 中各选项的延迟, 最长等待 8 秒, 按 Esc 取消..."
  delay_response="$(
    api_cancellable \
      -G "${API}/group/${group_url}/delay" \
      --data-urlencode 'url=https://cp.cloudflare.com' \
      --data-urlencode 'timeout=8000' \
      --data-urlencode 'expected=200/204'
  )"
  status=$?
  if (( status == 130 )); then return 130; fi
  if (( status != 0 )); then delay_response='{}'; fi

  while IFS= read -r node; do
    [[ -z $node ]] && continue
    type="$(jq -r --arg node "$node" '.proxies[$node].type // ""' <<<"$all_response")"
    has_children="$(jq -r --arg node "$node" 'if .proxies[$node].all != null then "true" else "false" end' <<<"$all_response")"

    if [[ $has_children == true ]]; then
      strategy_nodes+=("$node")
    else
      case "$node:$type" in
        DIRECT:*|REJECT:*|REJECT-DROP:*|PASS:*|PASS-RULE:*|COMPATIBLE:*|DNS:*|*:Direct|*:Reject|*:Pass|*:Compatible|*:DNS)
          special_nodes+=("$node")
          ;;
        *)
          actual_nodes+=("$node")
          ;;
      esac
    fi
  done < <(jq -r '.all[]' <<<"$response")

  if (( ${#strategy_nodes[@]} > 0 )); then
    for node in "${strategy_nodes[@]}"; do
      if [[ $node == "$current" ]]; then
        ordered_strategy_nodes+=("$node")
        break
      fi
    done
    for node in "${strategy_nodes[@]}"; do
      if [[ $node != "$current" ]]; then
        ordered_strategy_nodes+=("$node")
      fi
    done
    strategy_nodes=("${ordered_strategy_nodes[@]}")
  fi

  if (( ${#actual_nodes[@]} > 0 )); then
    actual_nodes_json="$(printf '%s\n' "${actual_nodes[@]}" | jq -Rn '[inputs]')"
    mapfile -t actual_nodes < <(
      jq -nr \
        --argjson nodes "$actual_nodes_json" \
        --argjson delays "$delay_response" '
          [
            $nodes[]
            | {name: ., delay: ($delays[.] // null)}
          ]
          | sort_by(
              if .delay == null
              then [1, 999999, .name]
              else [0, .delay, .name]
              end
            )
          | .[].name
        '
    )
  fi

  echo
  echo "当前选择: ${current:-未选择}"
  echo "* 表示当前选择."

  if (( ${#strategy_nodes[@]} > 0 )); then
    echo
    echo "========== 子策略组 =========="
    for node in "${strategy_nodes[@]}"; do
      type="$(jq -r --arg node "$node" '.proxies[$node].type // "未知"' <<<"$all_response")"
      child_current="$(jq -r --arg node "$node" '.proxies[$node].now // "未选择"' <<<"$all_response")"
      delay="$(jq -r --arg node "$node" '.[$node] // empty' <<<"$delay_response")"
      case "$type" in
        Selector) type_label="手动选择" ;;
        URLTest) type_label="自动测速" ;;
        Fallback) type_label="故障回退" ;;
        LoadBalance) type_label="负载均衡" ;;
        *) type_label="$type" ;;
      esac
      marker=" "
      [[ $node == "$current" ]] && marker="*"
      if [[ -n $delay ]]; then
        printf '%3d) %s %s [%s, 当前: %s, %s ms]\n' "$option_number" "$marker" "$node" "$type_label" "$child_current" "$delay"
      else
        printf '%3d) %s %s [%s, 当前: %s, 延迟未返回]\n' "$option_number" "$marker" "$node" "$type_label" "$child_current"
      fi
      selectable_nodes+=("$node")
      ((option_number++))
    done
  fi

  if (( ${#actual_nodes[@]} > 0 )); then
    echo
    echo "========== 具体节点 =========="
    for node in "${actual_nodes[@]}"; do
      delay="$(jq -r --arg node "$node" '.[$node] // empty' <<<"$delay_response")"
      marker=" "
      [[ $node == "$current" ]] && marker="*"
      if [[ -n $delay ]]; then
        printf '%3d) %s %s [%s ms]\n' "$option_number" "$marker" "$node" "$delay"
      else
        printf '%3d) %s %s [超时或不支持测速]\n' "$option_number" "$marker" "$node"
      fi
      selectable_nodes+=("$node")
      ((option_number++))
    done
  fi

  if (( ${#special_nodes[@]} > 0 )); then
    echo
    echo "========== 特殊选项 =========="
    for node in "${special_nodes[@]}"; do
      marker=" "
      [[ $node == "$current" ]] && marker="*"
      case "$node" in
        DIRECT) description="直接连接" ;;
        REJECT|REJECT-DROP) description="拒绝连接" ;;
        PASS|PASS-RULE) description="继续匹配后续规则" ;;
        COMPATIBLE) description="兼容模式" ;;
        DNS) description="内部 DNS 出站" ;;
        *) description="内置选项" ;;
      esac
      printf '%3d) %s %s [%s]\n' "$option_number" "$marker" "$node" "$description"
      selectable_nodes+=("$node")
      ((option_number++))
    done
  fi

  if (( ${#selectable_nodes[@]} == 0 )); then
    echo "该策略组没有可选择的项目."
    return 1
  fi

  if ! read_choice_or_back "输入编号(Esc/0/回车返回): "; then
    echo "已返回, 当前选择未改变."
    return 130
  fi
  choice="$MENU_CHOICE"
  if [[ ! $choice =~ ^[0-9]+$ ]] || (( choice < 1 || choice > ${#selectable_nodes[@]} )); then
    echo "编号无效."
    return 1
  fi
  node="${selectable_nodes[$((choice - 1))]}"

  echo "正在将 ${group} 切换到: ${node}"

  data="$(jq -nc --arg name "$node" '{name: $name}')"
  api \
    -X PUT \
    -H 'Content-Type: application/json' \
    --data "$data" \
    "${API}/proxies/${group_url}" >/dev/null
  status=$?
  if (( status == 130 )); then return 130; fi
  if (( status != 0 )); then
    echo "节点切换失败, 原选择未确认改变."
    return 1
  fi

  echo "已将 ${group} 切换到: ${node}"
}

manage_global_nodes() {
  local response
  local nodes_json
  local result
  local status
  local node_count
  local current
  local node
  local delay
  local marker
  local selected_label
  local index
  local data
  local nodes=()
  local display_nodes=()

  response="$(api "${API}/proxies")" || return
  nodes_json="$(
    jq -c '
      [
        .proxies
        | to_entries[]
        | select(.value.all == null)
        | select(.key != "DIRECT" and .key != "REJECT" and .key != "PASS")
        | select(
            (.value.type // "") != "Direct"
            and (.value.type // "") != "Reject"
            and (.value.type // "") != "Pass"
            and (.value.type // "") != "Compatible"
            and (.value.type // "") != "DNS"
          )
        | .key
      ]
      | unique
    ' <<<"$response"
  )" || return 1
  node_count="$(jq 'length' <<<"$nodes_json")"
  if (( node_count == 0 )); then
    echo "当前订阅中没有找到可测速的实际代理节点."
    return 1
  fi

  if ! jq -e '.proxies.GLOBAL != null and .proxies.GLOBAL.all != null' <<<"$response" >/dev/null; then
    echo "Mihomo API 中没有可用于批量测速的 GLOBAL 策略组."
    return 1
  fi

  if resolve_main_proxy_response "$response" global; then
    current="$ACTIVE_NODE"
  else
    current="$(jq -r '.proxies.GLOBAL.now // ""' <<<"$response")"
  fi

  echo "找到 ${node_count} 个实际代理节点."
  echo "正在测试全部节点延迟, 最长等待 8 秒, 按 Esc 取消..."
  result="$(
    api_cancellable \
      -G "${API}/group/GLOBAL/delay" \
      --data-urlencode 'url=https://cp.cloudflare.com' \
      --data-urlencode 'timeout=8000' \
      --data-urlencode 'expected=200/204'
  )"
  status=$?
  if (( status == 130 )); then return 130; fi
  if (( status != 0 )); then
    echo "测速请求失败."
    return 1
  fi

  mapfile -t nodes < <(
    jq -nr \
      --argjson nodes "$nodes_json" \
      --argjson delays "$result" '
      [
        $nodes[]
        | {name: ., delay: ($delays[.] // null)}
      ]
      | sort_by(
          if .delay == null
          then [1, 999999, .name]
          else [0, .delay, .name]
          end
        )
      | .[].name
    '
  )

  for node in "${nodes[@]}"; do
    delay="$(jq -r --arg node "$node" '.[$node] // empty' <<<"$result")"
    marker=" "
    if [[ $node == "$current" ]]; then
      marker="*"
    fi

    if [[ -n $delay ]]; then
      display_nodes+=("${marker} ${node} [${delay} ms]")
    else
      display_nodes+=("${marker} ${node} [超时或不可用]")
    fi
  done

  echo "* 表示当前全局节点."
  choose_item "选择 GLOBAL 使用的具体节点:" "${display_nodes[@]}"
  status=$?
  if (( status == 130 )); then return 130; fi
  if (( status != 0 )); then return "$status"; fi
  selected_label="$SELECTED"

  node=""
  for index in "${!display_nodes[@]}"; do
    if [[ ${display_nodes[$index]} == "$selected_label" ]]; then
      node="${nodes[$index]}"
      break
    fi
  done
  if [[ -z $node ]]; then
    echo "无法识别节点选择结果."
    return 1
  fi

  data="$(jq -nc --arg name "$node" '{name: $name}')"
  api \
    -X PUT \
    -H 'Content-Type: application/json' \
    --data "$data" \
    "${API}/proxies/GLOBAL" >/dev/null
  status=$?
  if (( status == 130 )); then return 130; fi
  if (( status != 0 )); then
    echo "全局节点切换失败, 原选择未确认改变."
    return 1
  fi

  echo "GLOBAL 已切换到: ${node}"
}

manage_nodes_by_mode() {
  local config_response
  local mode
  local status

  require_api || return
  config_response="$(api "${API}/configs")"
  status=$?
  if (( status == 130 )); then return 130; fi
  if (( status != 0 )); then
    echo "无法读取当前运行模式."
    return 1
  fi
  mode="$(jq -r '.mode // empty' <<<"$config_response")"

  case "$mode" in
    rule)
      echo "当前为规则分流模式. 请先选择策略组, 随后按测速结果选择节点."
      manage_rule_nodes
      ;;
    global)
      echo "当前为全局代理模式. 将测试全部实际节点并直接设置 GLOBAL 节点."
      manage_global_nodes
      ;;
    direct)
      echo "当前为全部直连模式, 不使用代理节点."
      echo "如需选择节点, 请先在主菜单切换到 rule 或 global 模式."
      ;;
    *)
      echo "无法识别当前运行模式: ${mode:-空}"
      return 1
      ;;
  esac
}

show_connections() {
