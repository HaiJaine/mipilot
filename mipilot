    return 1
  }
  atomic_install_file 600 "$selected_copy" "$CONFIG_FILE" || {
    sudo rm -f -- "$selected_copy"
    return 1
  }
  sudo rm -f -- "$selected_copy"
  if ! restart_mihomo_with_progress || ! wait_mihomo_with_progress 3; then
    if rollback_config "$current_backup" && wait_mihomo_with_progress 3; then
