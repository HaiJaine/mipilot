rollback_created_label() {
  local kind="$1"
  local created

  created="$(sudo cat "${ROLLBACK_DIR}/${kind}/created_at" 2>/dev/null || true)"
  if [[ $created =~ ^[0-9]+$ ]]; then
    date -d "@${created}" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || printf '%s' "$created"
  else
    printf '未知时间'
  fi
}

rollback_is_usable() {
  local kind="$1"
  local slot

  slot="$(rollback_slot_path "$kind")" || return 1
  sudo test -d "$slot" || return 1
  sudo test -f "${slot}/absent" && return 1
  case "$kind" in
    core) sudo test -x "${slot}/mihomo" ;;
    geo) sudo test -f "${slot}/Country.mmdb" && sudo test -f "${slot}/GeoSite.dat" ;;
    manager) sudo test -f "${slot}/mipilot" ;;
  esac
}

manual_rollback_core() {
  local current
  local current_version

  rollback_is_usable core || {
    echo "没有可用的内核回退版本."
    return 1
  }
  current="$(mktemp /tmp/mihomo-current-core.XXXXXX)" || return 1
  sudo install -m 755 "$MIHOMO_BIN" "$current" || {
    sudo rm -f -- "$current"
    return 1
  }
  current_version="$(current_core_version)"
  if ! stop_mihomo_for_update; then
    sudo rm -f -- "$current"
    echo "无法停止 Mihomo 服务, 已取消内核回退."
    return 1
  fi
  if ! restore_component_rollback core; then
    if atomic_install_file 755 "$current" "$MIHOMO_BIN" && start_mihomo_with_progress && wait_mihomo_with_progress 3 "$current_version"; then
      sudo rm -f -- "$current"
      echo "回退文件写入失败, 已恢复回退前内核."
    else
      echo "严重错误: 回退文件写入失败且当前内核未能恢复, 当前副本位于 ${current}."
    fi
    return 1
  fi
  if ! run_cancellable_named "正在验证回退内核" 45 sudo -n "$MIHOMO_BIN" -t -d "$CONFIG_DIR" || \
     ! restart_mihomo_with_progress || ! wait_mihomo_with_progress 3; then
    if atomic_install_file 755 "$current" "$MIHOMO_BIN" && restart_mihomo_with_progress && wait_mihomo_with_progress 3; then
      echo "回退内核未能运行, 已恢复回退前版本."
    else
      echo "严重错误: 回退内核和回退前版本均未能恢复, 当前副本位于 ${current}."
      return 1
    fi
    sudo rm -f -- "$current"
    return 1
  fi
  sudo rm -f -- "$current"
  sudo rm -rf -- "${ROLLBACK_DIR:?}/core"
  echo "内核已回退到最近一次保留版本."
}

