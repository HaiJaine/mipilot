SELECTED=""
MENU_CHOICE=""
INPUT_LINE=""
ACTIVE_NODE=""
ACTIVE_CHAIN=""
MENU_MODE_STATUS=""
MENU_NODE_STATUS=""
MENU_RUNTIME_MODE=""
