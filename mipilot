install_manager_files() {
  local marker_temporary

  sudo install -d -m 755 "$MANAGER_LIB_DIR" || return 1
  if [[ $SCRIPT_PATH != "$MANAGER_INSTALLED_SCRIPT" ]]; then
    atomic_install_file 755 "$SCRIPT_PATH" "$MANAGER_INSTALLED_SCRIPT" || return 1
  fi
  write_manager_wrapper || return 1
  sudo install -d -m 700 "$STATE_DIR" "$ROLLBACK_DIR" || return 1
  if sudo test -f "$CONFIG_FILE"; then
    refresh_tun_bypass_ports || return 1
    sync_tun_bypass_rules || return 1
  fi
  write_cleanup_units || return 1
  write_tun_bypass_unit || return 1
  ensure_shell_integration || return 1
  marker_temporary="$(mktemp /tmp/mipilot-marker.XXXXXX)" || return 1
  {
    printf 'version=%s\n' "$MANAGER_VERSION"
    printf 'installed_at=%s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    printf 'installed_by=%s\n' "${USER:-unknown}"
  } >"$marker_temporary"
  atomic_install_file 600 "$marker_temporary" "$INSTALL_MARKER" || {
    rm -f -- "$marker_temporary"
    return 1
  }
  rm -f -- "$marker_temporary"
}

validate_existing_config_with_staged_core() {
  local validation_dir

  sudo test -f "$CONFIG_FILE" || return 1
  validation_dir="$(mktemp -d /tmp/mipilot-existing.XXXXXX)" || return 1
  sudo cp -a "${CONFIG_DIR}/." "$validation_dir/" || {
    sudo rm -rf -- "$validation_dir"
    return 1
  }
  sudo install -m 644 "$LOCAL_COUNTRY_MMDB" "${validation_dir}/Country.mmdb"
  sudo install -m 644 "$LOCAL_GEOSITE_DAT" "${validation_dir}/GeoSite.dat"
  sudo "$STAGED_MIHOMO_BIN" -t -d "$validation_dir"
  local status=$?
  sudo rm -rf -- "$validation_dir"
  return "$status"
}

rollback_local_install() {
  local config_backup="${1:-}"
  local had_config="${2:-0}"
  local failed=0
  local restored_version

  restore_component_rollback core || failed=1
  restore_component_rollback geo || failed=1
  restore_component_rollback service || failed=1
  if [[ -n $config_backup ]]; then
    atomic_install_file 600 "$config_backup" "$CONFIG_FILE" || failed=1
  elif (( had_config == 0 )); then
    sudo rm -f -- "$CONFIG_FILE" || failed=1
  fi
  sudo systemctl daemon-reload || failed=1
  if service_exists; then
    restored_version="$(current_core_version)"
    if ! run_blocking "正在启用并启动 Mihomo 服务" 45 \
         sudo -n systemctl enable --now mihomo || \
       ! wait_mihomo_with_progress 3 "$restored_version"; then
      failed=1
    fi
  fi
  if (( failed == 0 )); then
    echo "安装失败, 已恢复安装前的内核、数据、配置和服务."
    return 0
  fi
  echo "严重错误: 安装失败且自动恢复未完成."
  echo "组件回退目录: ${ROLLBACK_DIR}"
  [[ -n $config_backup ]] && echo "配置备份: ${config_backup}"
  return 1
}

clear_manager_runtime_state() {
  local empty_list

  empty_list="$(mktemp /tmp/mihomo-empty-subscriptions.XXXXXX)" || return 1
  sudo rm -f -- "$SUBSCRIPTION_FILE" "$SUBSCRIPTION_LIST_FILE" "$REGION_STATE_FILE" "$TUN_STATE_FILE" || {
    rm -f -- "$empty_list"
    return 1
  }
  atomic_install_file 600 "$empty_list" "$SUBSCRIPTION_LIST_FILE" || {
    rm -f -- "$empty_list"
    return 1
  }
  rm -f -- "$empty_list"
  save_tun_state false || return 1
  sync_tun_bypass_rules || return 1
  write_proxy_state 0 || return 1
  apply_proxy_state
}

install_from_local_bundle() {
  local asset_directory="$1"
  local config_mode="${2:-preserve}"
  local config_temporary=""
  local config_backup=""
  local runtime_snapshot=""
  local had_config=0
  local status

  if ! find_local_assets "$asset_directory"; then
    echo "本地安装包不完整: ${asset_directory}"
    show_required_local_assets
    return 1
  fi
  echo "正在校验本地内核和地理数据..."
  validate_local_assets || return 1

  if sudo test -f "$CONFIG_FILE"; then had_config=1; fi
  if [[ $config_mode == preserve && $had_config == 1 ]]; then
    echo "正在使用新内核预检现有配置..."
    validate_existing_config_with_staged_core || {
      rm -f -- "$STAGED_MIHOMO_BIN"
      echo "现有配置无法通过新内核验证, 尚未修改系统."
      return 1
    }
  else
    config_temporary="$(mktemp /tmp/mipilot-initial.XXXXXX.yaml)" || return 1
    render_minimal_config "$config_temporary" || return 1
    "$STAGED_MIHOMO_BIN" -t -d "$(dirname -- "$config_temporary")" -f "$config_temporary" || {
      rm -f -- "$STAGED_MIHOMO_BIN" "$config_temporary"
      return 1
    }
    if (( had_config == 1 )); then
      config_backup="$(create_config_backup reinstall)" || return 1
    fi
  fi

  echo "所有文件已校验, 正在保存最近版本并重建服务; 此阶段不可中断."
  save_component_rollback core || return 1
  save_component_rollback geo || return 1
  save_component_rollback service || return 1
  if service_exists; then
    if ! run_blocking "正在停止旧 Mihomo 服务" 45 \
         sudo -n systemctl disable --now mihomo; then
      echo "无法停止旧 Mihomo 服务, 尚未替换任何核心文件."
      return 1
    fi
    if sudo systemctl is-active --quiet mihomo; then
      echo "旧 Mihomo 服务仍在运行, 安装已停止."
      return 1
    fi
  fi
  sudo install -d -m 700 "$CONFIG_DIR" || {
    rollback_local_install "$config_backup" "$had_config"
    return 1
  }
  atomic_install_file 755 "$STAGED_MIHOMO_BIN" "$MIHOMO_BIN" || {
    rollback_local_install "$config_backup" "$had_config"
    return 1
  }
  atomic_install_file 644 "$LOCAL_COUNTRY_MMDB" "${CONFIG_DIR}/Country.mmdb" || {
    rollback_local_install "$config_backup" "$had_config"
    return 1
  }
  atomic_install_file 644 "$LOCAL_GEOSITE_DAT" "${CONFIG_DIR}/GeoSite.dat" || {
    rollback_local_install "$config_backup" "$had_config"
    return 1
  }
  if [[ -n $config_temporary ]]; then
    atomic_install_file 600 "$config_temporary" "$CONFIG_FILE" || {
      rollback_local_install "$config_backup" "$had_config"
      return 1
    }
  fi
  write_service_unit || {
    rollback_local_install "$config_backup" "$had_config"
    return 1
  }
  sudo "$MIHOMO_BIN" -t -d "$CONFIG_DIR"
  status=$?
  if (( status != 0 )); then
    rollback_local_install "$config_backup" "$had_config"
    rm -f -- "$STAGED_MIHOMO_BIN" "$config_temporary"
    return 1
  fi
  if ! sudo systemctl daemon-reload; then
    rollback_local_install "$config_backup" "$had_config"
    return 1
  fi
  run_blocking "正在启用并启动 Mihomo 服务" 45 \
    sudo -n systemctl enable --now mihomo || {
    rollback_local_install "$config_backup" "$had_config"
    return 1
  }
  if ! wait_for_mihomo_stable 3; then
    rollback_local_install "$config_backup" "$had_config" || true
    rm -f -- "$STAGED_MIHOMO_BIN" "$config_temporary"
    return 1
  fi
  if [[ $config_mode == reset ]]; then
    runtime_snapshot="$(mktemp -d /tmp/mihomo-reinstall-state.XXXXXX)" || {
      rollback_local_install "$config_backup" "$had_config" || true
      return 1
    }
    snapshot_manager_runtime_state "$runtime_snapshot" || {
      sudo rm -rf -- "$runtime_snapshot"
      rollback_local_install "$config_backup" "$had_config" || true
      return 1
    }
    clear_manager_runtime_state || {
      if restore_manager_runtime_state "$runtime_snapshot"; then
        sudo rm -rf -- "$runtime_snapshot"
      else
        echo "严重错误: 旧订阅状态恢复失败, 安全快照保留在 ${runtime_snapshot}."
      fi
      rollback_local_install "$config_backup" "$had_config" || true
      return 1
    }
    sudo rm -rf -- "$runtime_snapshot"
  fi
  install_manager_files || {
    echo "Mihomo 已安装, 但管理命令安装失败. 再次运行脚本可进入修复流程."
    return 1
  }
  migrate_legacy_backups || true
  cleanup_expired_rollbacks || true
  rm -f -- "$STAGED_MIHOMO_BIN" "$config_temporary"
  STAGED_MIHOMO_BIN=""
  echo "Mihomo 和 mipilot 已安装完成."
  [[ -n $config_backup ]] && echo "原配置备份: ${config_backup}"
}

acquire_manager_lock() {
  local lock_parent

  lock_parent="$(dirname -- "$LOCK_FILE")"
  if ! sudo test -d "$lock_parent"; then
    sudo install -d -m 755 "$lock_parent" || return 1
  fi
  if ! sudo test -e "$LOCK_FILE"; then
    sudo touch "$LOCK_FILE" || return 1
    sudo chown "$(id -u):$(id -g)" "$LOCK_FILE" || return 1
    chmod 600 "$LOCK_FILE" || return 1
  elif [[ ! -w $LOCK_FILE ]]; then
    sudo chown "$(id -u):$(id -g)" "$LOCK_FILE" || return 1
  fi
  exec 9>"$LOCK_FILE" || return 1
  if ! flock -n 9; then
    echo "另一个 mipilot 正在运行, 请稍后再试."
    return 1
  fi
}

release_manager_lock() {
  flock -u 9 2>/dev/null || true
  exec 9>&- || true
}

adopt_existing_install() {
  local existing_binary
  local service_exec_start

  if ! command -v mihomo >/dev/null 2>&1 && [[ ! -x $MIHOMO_BIN ]]; then
    echo "找不到可执行的 Mihomo 内核, 无法接管."
    return 1
  fi
  if ! sudo test -f "$CONFIG_FILE" || ! service_exists; then
    echo "现有安装不完整, 请使用离线包修复."
    return 1
  fi
  existing_binary="$(command -v mihomo 2>/dev/null || printf '%s' "$MIHOMO_BIN")"
  if [[ $(readlink -f -- "$existing_binary") != $(readlink -f -- "$MIHOMO_BIN") ]]; then
    echo "现有内核不在受支持路径 ${MIHOMO_BIN}: ${existing_binary}"
    echo "请选择使用离线包重新安装, 以统一内核和服务路径."
    return 1
  fi
  service_exec_start="$(systemctl show mihomo -p ExecStart --value 2>/dev/null || true)"
  if [[ $service_exec_start != *"${MIHOMO_BIN}"* ]]; then
    echo "现有 mihomo.service 未使用受支持内核路径 ${MIHOMO_BIN}."
    echo "请选择使用离线包重新安装, 以避免更新了文件却仍运行旧内核."
    return 1
  fi
  install_manager_files || return 1
  migrate_legacy_backups || true
  cleanup_expired_rollbacks || true
  echo "已无损接管现有 Mihomo, 当前内核、配置和服务均未替换."
}

choose_reinstall_config_mode() {
  echo "请选择离线重装时的配置处理方式:"
  echo "  1) 保留当前配置、订阅和节点"
  echo "  2) 备份后全部重置为初始直连配置"
  read_choice_or_back "输入编号(Esc/0返回): " || return 130
  case "$MENU_CHOICE" in
    1) SELECTED="preserve" ;;
    2) SELECTED="reset" ;;
    *) echo "无效选项."; return 1 ;;
  esac
}

offer_initial_subscription() {
  local status

  ensure_subscription_list || return 1
  refresh_api_config
  read_line_or_back "是否现在添加订阅? (y/N, Esc跳过): "
  status=$?
  if (( status == 130 )); then return 0; fi
  if (( status != 0 )); then return 1; fi
  case "${INPUT_LINE,,}" in
    y|yes)
      add_managed_subscription || {
        echo "订阅未成功添加, Mihomo 仍保持安全直连配置."
        return 0
      }
      ;;
    *) echo "已跳过订阅, 当前使用直连配置." ;;
  esac
}

run_install_wizard() {
  local state="$1"
  local config_mode="reset"

  case "$state" in
    existing)
      echo "检测到已有但尚未由 mipilot 管理的 Mihomo."
      echo "  1) 直接接管现有安装(不替换内核、配置和服务)"
      echo "  2) 使用脚本同级离线包重新安装并重建服务"
      read_choice_or_back "输入编号(Esc/0退出): " || return 130
      case "$MENU_CHOICE" in
        1) adopt_existing_install || return 1 ;;
        2)
          choose_reinstall_config_mode || return $?
          config_mode="$SELECTED"
          install_from_local_bundle "$SCRIPT_DIR" "$config_mode" || return 1
          ;;
        *) echo "无效选项."; return 1 ;;
      esac
      ;;
    absent)
      echo "未检测到 Mihomo, 即将使用脚本同级离线包执行首次安装."
      install_from_local_bundle "$SCRIPT_DIR" reset || return 1
      offer_initial_subscription
      ;;
    partial)
      echo "检测到不完整的 Mihomo 或 mipilot 安装."
      if command -v mihomo >/dev/null 2>&1 && sudo test -f "$CONFIG_FILE" && service_exists; then
        echo "核心组件完整, 正在修复管理命令和状态文件."
        adopt_existing_install || return 1
      else
        echo "需要使用脚本同级离线包修复核心组件和服务."
        if sudo test -f "$CONFIG_FILE"; then
          choose_reinstall_config_mode || return $?
          config_mode="$SELECTED"
        fi
        install_from_local_bundle "$SCRIPT_DIR" "$config_mode" || return 1
      fi
      ;;
  esac

  echo
  echo "安装或接管完成. 请执行:"
  echo "  source ~/.bashrc"
  echo "  mipilot"
}

installed_manager_version() {
  sudo awk -F= '$1 == "version" { print $2; exit }' "$INSTALL_MARKER" 2>/dev/null
}

version_is_newer() {
  local candidate="$1"
  local current="$2"
  local candidate_core
  local current_core
  local candidate_pre=""
  local current_pre=""
  local -a candidate_parts
  local -a current_parts
  local index

  [[ $candidate =~ ^[0-9]+\.[0-9]+\.[0-9]+(-[0-9A-Za-z.-]+)?$ ]] || return 1
  [[ $current =~ ^[0-9]+\.[0-9]+\.[0-9]+(-[0-9A-Za-z.-]+)?$ ]] || return 1
  candidate_core="${candidate%%-*}"
  current_core="${current%%-*}"
  [[ $candidate == *-* ]] && candidate_pre="${candidate#*-}"
  [[ $current == *-* ]] && current_pre="${current#*-}"
  IFS=. read -r -a candidate_parts <<<"$candidate_core"
  IFS=. read -r -a current_parts <<<"$current_core"
  for index in 0 1 2; do
    if (( 10#${candidate_parts[$index]} > 10#${current_parts[$index]} )); then
      return 0
    elif (( 10#${candidate_parts[$index]} < 10#${current_parts[$index]} )); then
      return 1
    fi
  done
  [[ -z $candidate_pre && -n $current_pre ]] && return 0
  [[ -n $candidate_pre && -z $current_pre ]] && return 1
  [[ -n $candidate_pre && -n $current_pre && $candidate_pre != "$current_pre" ]] || return 1
  [[ $(printf '%s\n%s\n' "$candidate_pre" "$current_pre" | sort -V | tail -n 1) == "$candidate_pre" ]]
}

offer_local_manager_upgrade() {
  local installed_version
  local status

  installed_version="$(installed_manager_version)"
  if [[ -n $installed_version ]] && version_is_newer "$MANAGER_VERSION" "$installed_version"; then
    echo "检测到本地管理脚本可升级: ${installed_version} -> ${MANAGER_VERSION}"
    read_line_or_back "是否安装这个本地版本? (Y/n): "
    status=$?
    if (( status != 0 )); then return "$status"; fi
    case "${INPUT_LINE,,}" in
      ""|y|yes) ensure_sudo_access && install_manager_files ;;
      *) echo "已保留当前管理脚本版本." ;;
    esac
  fi
}

current_core_version() {
  if sudo test -x "$MIHOMO_BIN"; then
    sudo "$MIHOMO_BIN" -v 2>/dev/null | awk 'NR == 1 { print $3; exit }'
  else
    mihomo -v 2>/dev/null | awk 'NR == 1 { print $3; exit }'
  fi
}

start_mihomo_with_progress() {
  ensure_sudo_access || return 1
  run_blocking "正在启动 Mihomo 服务" 35 sudo -n systemctl start mihomo
}

restart_mihomo_with_progress() {
  ensure_sudo_access || return 1
  run_blocking "正在重启 Mihomo 服务" 35 sudo -n systemctl restart mihomo
}

stop_mihomo_with_progress() {
  ensure_sudo_access || return 1
  run_blocking "正在停止 Mihomo 服务" 35 sudo -n systemctl stop mihomo
}

wait_mihomo_with_progress() {
  local checks="${1:-3}"
  local expected_version="${2:-}"

  run_blocking "正在等待 Mihomo 服务稳定" 20 \
    wait_for_mihomo_stable "$checks" "$expected_version"
}

stop_mihomo_for_update() {
  if ! stop_mihomo_with_progress; then
    if ! sudo systemctl is-active --quiet mihomo; then
      start_mihomo_with_progress >/dev/null 2>&1 || true
    fi
    return 1
  fi
  ! sudo systemctl is-active --quiet mihomo
}

recover_core_after_failed_update() {
  if restore_component_rollback core && restart_mihomo_with_progress && wait_mihomo_with_progress 3; then
    echo "新内核启动失败, 已恢复上一个版本."
    return 0
  fi
  echo "严重错误: 新内核失败且自动恢复未完成. 回退文件位于 ${ROLLBACK_DIR}/core."
  return 1
}

recover_geo_after_failed_update() {
  if restore_component_rollback geo && restart_mihomo_with_progress && wait_mihomo_with_progress 3; then
    echo "新地理数据未能稳定运行, 已恢复上一个版本."
    return 0
  fi
  echo "严重错误: 地理数据更新失败且自动恢复未完成. 回退文件位于 ${ROLLBACK_DIR}/geo."
  return 1
}

download_file() {
  local url="$1"
  local output_file="$2"
  local label="${3:-下载文件}"
  local attempt
  local status

  if (( DOWNLOAD_ROUTE_NOTICE_SHOWN == 0 )); then
    echo "网络路径由当前TUN、代理环境变量或系统路由决定."
    DOWNLOAD_ROUTE_NOTICE_SHOWN=1
  fi
  for attempt in 1 2 3; do
    if (( attempt == 1 )); then
      echo "正在下载: ${label}"
    else
      echo "正在重试: ${label} (${attempt}/3)"
    fi
    run_cancellable_named "正在下载 ${label}" 185 \
      curl -4 -fL -sS --show-error --connect-timeout 15 --max-time 180 \
      "$url" -o "$output_file"
    status=$?
    if (( status == 0 )); then
      return 0
    fi
    if (( status == 130 )); then
      return 130
    fi
    if (( status == 22 )); then
      echo "服务器返回HTTP错误, 不再重复请求. 如果GitHub提示403, 通常是当前出口IP的匿名API额度已耗尽."
      return 22
    fi
    rm -f -- "$output_file"
    (( attempt < 3 )) && sleep 2
  done
  return "$status"
}

update_core_from_archive() {
  local archive="$1"
  local source_label="${2:-本地文件}"
  local staged
  local current_version
  local new_version
  local status

  gzip -t "$archive" || {
    echo "内核压缩包校验失败: ${archive}"
    return 1
  }
  staged="$(mktemp /tmp/mipilot-update-core.XXXXXX)" || return 1
  gzip -dc "$archive" >"$staged" || {
    rm -f -- "$staged"
    return 1
  }
  chmod 755 "$staged"
  new_version="$("$staged" -v 2>/dev/null | awk 'NR == 1 { print $3; exit }')"
  current_version="$(current_core_version)"
  if [[ -z $new_version || $new_version != v* ]]; then
    echo "无法识别待安装内核版本."
    rm -f -- "$staged"
    return 1
  fi
  echo "当前内核: ${current_version:-未知}"
  echo "待安装内核: ${new_version} (${source_label})"
  if [[ $new_version == "$current_version" ]]; then
    echo "内核版本相同, 无需更新."
    rm -f -- "$staged"
    return 0
  fi
  if [[ -n $current_version ]] && ! version_is_newer "${new_version#v}" "${current_version#v}"; then
    read_line_or_back "检测到降级, 是否继续? (y/N, Esc取消): "
    status=$?
    if (( status != 0 )); then rm -f -- "$staged"; return "$status"; fi
    case "${INPUT_LINE,,}" in
      y|yes) ;;
      *) rm -f -- "$staged"; echo "已取消内核降级."; return 130 ;;
    esac
  fi

  run_cancellable_named "正在用新内核验证现有配置" 45 \
    sudo -n "$staged" -t -d "$CONFIG_DIR"
  status=$?
  if (( status != 0 )); then
    rm -f -- "$staged"
    return "$status"
  fi
  save_component_rollback core || {
    rm -f -- "$staged"
    return 1
  }
  if ! stop_mihomo_for_update; then
    echo "无法停止 Mihomo 服务, 内核更新已取消."
    rm -f -- "$staged"
    return 1
  fi
  atomic_install_file 755 "$staged" "$MIHOMO_BIN" || {
    recover_core_after_failed_update || true
    rm -f -- "$staged"
    return 1
  }
  rm -f -- "$staged"
  if ! start_mihomo_with_progress || ! wait_mihomo_with_progress 3 "$new_version"; then
    recover_core_after_failed_update || true
    return 1
  fi
  cleanup_expired_rollbacks || true
  echo "Mihomo 内核已更新到 ${new_version}."
}

validate_geo_files() {
  local country_file="$1"
  local geosite_file="$2"
  local validation_dir

  [[ -s $country_file && -s $geosite_file ]] || return 1
  validation_dir="$(mktemp -d /tmp/mipilot-geo.XXXXXX)" || return 1
  install -m 644 "$country_file" "${validation_dir}/Country.mmdb"
  install -m 644 "$geosite_file" "${validation_dir}/GeoSite.dat"
  cat >"${validation_dir}/config.yaml" <<'EOF'
mode: direct
log-level: silent
proxies: []
proxy-groups: []
rules:
  - GEOSITE,cn,DIRECT
  - GEOIP,cn,DIRECT,no-resolve
  - MATCH,DIRECT
EOF
  sudo -n "$MIHOMO_BIN" -t -d "$validation_dir" -f "${validation_dir}/config.yaml"
  local status=$?
  rm -rf -- "$validation_dir"
  return "$status"
}

update_geo_from_files() {
  local country_file="$1"
  local geosite_file="$2"
  local current_country_hash=""
  local current_geosite_hash=""
  local new_country_hash
  local new_geosite_hash

  ensure_sudo_access || return 1
  run_blocking "正在验证 Country.mmdb 和 GeoSite.dat" 60 \
    validate_geo_files "$country_file" "$geosite_file" || return 1
  if sudo test -f "${CONFIG_DIR}/Country.mmdb"; then
    current_country_hash="$(sudo sha256sum "${CONFIG_DIR}/Country.mmdb" | awk '{print $1}')"
  fi
  if sudo test -f "${CONFIG_DIR}/GeoSite.dat"; then
    current_geosite_hash="$(sudo sha256sum "${CONFIG_DIR}/GeoSite.dat" | awk '{print $1}')"
  fi
  new_country_hash="$(sha256sum "$country_file" | awk '{print $1}')"
  new_geosite_hash="$(sha256sum "$geosite_file" | awk '{print $1}')"
  if [[ $current_country_hash == "$new_country_hash" && $current_geosite_hash == "$new_geosite_hash" ]]; then
    echo "地理数据与当前版本相同, 无需更新."
    return 0
  fi

  save_component_rollback geo || return 1
  if ! stop_mihomo_for_update; then
    echo "无法停止 Mihomo 服务, 地理数据更新已取消."
    return 1
  fi
  atomic_install_file 644 "$country_file" "${CONFIG_DIR}/Country.mmdb" || {
    recover_geo_after_failed_update || true
    return 1
  }
  atomic_install_file 644 "$geosite_file" "${CONFIG_DIR}/GeoSite.dat" || {
    recover_geo_after_failed_update || true
    return 1
  }
  if ! run_cancellable_named "正在验证更新后的地理数据" 45 \
       sudo -n "$MIHOMO_BIN" -t -d "$CONFIG_DIR" || \
     ! start_mihomo_with_progress || ! wait_mihomo_with_progress 3; then
    recover_geo_after_failed_update || true
    return 1
  fi
  cleanup_expired_rollbacks || true
  echo "Country.mmdb 和 GeoSite.dat 已更新."
}

online_update_core() {
  local release_json
  local archive
  local asset_record
  local asset_name
  local asset_url
  local digest
  local expected_hash
  local actual_hash

  release_json="$(mktemp /tmp/mihomo-release.XXXXXX.json)" || return 1
  archive="$(mktemp /tmp/mihomo-release.XXXXXX.gz)" || return 1
  if ! download_file "https://api.github.com/repos/MetaCubeX/mihomo/releases/latest" "$release_json" "Mihomo 最新版本信息"; then
    rm -f -- "$release_json" "$archive"
    show_manual_download_help
    return 1
  fi
  asset_record="$(jq -r '
    .assets[]
    | select(.name | test("^mihomo-linux-amd64-v[0-9]+\\.[0-9]+\\.[0-9]+\\.gz$"))
    | [.name, .browser_download_url, (.digest // "")]
    | @tsv
  ' "$release_json" | head -n 1)"
  IFS=$'\t' read -r asset_name asset_url digest <<<"$asset_record"
  if [[ -z $asset_name || -z $asset_url || $digest != sha256:* ]]; then
    echo "官方Release中找不到可校验的Linux amd64稳定版资产."
    rm -f -- "$release_json" "$archive"
    return 1
  fi
  download_file "$asset_url" "$archive" "Mihomo 内核 ${asset_name}" || {
    rm -f -- "$release_json" "$archive"
    show_manual_download_help
    return 1
  }
  expected_hash="${digest#sha256:}"
  actual_hash="$(sha256sum "$archive" | awk '{print $1}')"
  if [[ $actual_hash != "$expected_hash" ]]; then
    echo "内核SHA256校验失败, 未执行更新."
    rm -f -- "$release_json" "$archive"
    return 1
  fi
  update_core_from_archive "$archive" "$asset_name"
  local status=$?
  rm -f -- "$release_json" "$archive"
  return "$status"
}

verify_sha256_sidecar() {
  local file="$1"
  local sidecar="$2"
  local expected
  local actual

  expected="$(awk 'NR == 1 { print $1; exit }' "$sidecar")"
  actual="$(sha256sum "$file" | awk '{print $1}')"
  [[ $expected =~ ^[0-9a-fA-F]{64}$ && ${expected,,} == "$actual" ]]
}

manager_version_from_script() {
  local script="$1"

  awk -F'"' '
    /^MANAGER_VERSION="[0-9]+[.][0-9]+[.][0-9]+(-[0-9A-Za-z.-]+)?"$/ {
      count++
      version = $2
    }
    END {
      if (count == 1) print version
      else exit 1
    }
  ' "$script"
}

write_manager_install_marker() {
  local version="$1"
  local temporary

  temporary="$(mktemp /tmp/mipilot-marker.XXXXXX)" || return 1
  {
    printf 'version=%s\n' "$version"
    printf 'installed_at=%s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    printf 'installed_by=%s\n' "${USER:-unknown}"
  } >"$temporary"
  atomic_install_file 600 "$temporary" "$INSTALL_MARKER"
  local status=$?
  rm -f -- "$temporary"
  return "$status"
}

online_update_manager() {
  local temporary_dir
  local candidate
  local sidecar
  local candidate_version
  local status

  temporary_dir="$(mktemp -d /tmp/mipilot-manager-update.XXXXXX)" || return 1
  candidate="${temporary_dir}/mipilot"
  sidecar="${temporary_dir}/mipilot.sha256"
  download_file "${MANAGER_RELEASE_BASE}/mipilot" "$candidate" "MiPilot 稳定版脚本" || {
    rm -rf -- "$temporary_dir"
    echo "无法下载稳定版管理脚本, 当前版本未改变."
    return 1
  }
  download_file "${MANAGER_RELEASE_BASE}/mipilot.sha256" "$sidecar" "MiPilot 脚本摘要" || {
    rm -rf -- "$temporary_dir"
    echo "无法下载脚本摘要, 当前版本未改变."
    return 1
  }
  if ! verify_sha256_sidecar "$candidate" "$sidecar"; then
    rm -rf -- "$temporary_dir"
    echo "MiPilot SHA-256 校验失败, 当前版本未改变."
    return 1
  fi
  if ! head -n 1 "$candidate" | grep -Fqx '#!/usr/bin/env bash' || \
     ! grep -Fq 'MANAGER_INSTALLED_SCRIPT=' "$candidate" || \
     ! run_cancellable_named "正在检查新管理脚本语法" 20 bash -n "$candidate"; then
    rm -rf -- "$temporary_dir"
    echo "下载的文件不是有效的 MiPilot 管理脚本."
    return 1
  fi
  candidate_version="$(manager_version_from_script "$candidate")" || {
    rm -rf -- "$temporary_dir"
    echo "无法识别新管理脚本版本."
    return 1
  }
  if [[ ! $candidate_version =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    rm -rf -- "$temporary_dir"
    echo "在线更新只接受稳定版本, 已拒绝 ${candidate_version}."
    return 1
  fi
  echo "当前 MiPilot: ${MANAGER_VERSION}"
  echo "最新稳定版: ${candidate_version}"
  if [[ $candidate_version == "$MANAGER_VERSION" ]]; then
    rm -rf -- "$temporary_dir"
    echo "当前已经是最新稳定版."
    return 0
  fi
  if ! version_is_newer "$candidate_version" "$MANAGER_VERSION"; then
    rm -rf -- "$temporary_dir"
    echo "稳定Release版本不高于当前版本, 已拒绝自动降级."
    return 1
  fi

  read_line_or_back "确认更新 MiPilot 到 ${candidate_version}? (y/N, Esc返回): "
  status=$?
  if (( status != 0 )); then rm -rf -- "$temporary_dir"; return "$status"; fi
  case "${INPUT_LINE,,}" in
    y|yes) ;;
    *) rm -rf -- "$temporary_dir"; echo "已取消管理器更新."; return 130 ;;
  esac

  ensure_sudo_access || { rm -rf -- "$temporary_dir"; return 1; }
  save_component_rollback manager || {
    rm -rf -- "$temporary_dir"
    echo "无法保存当前管理器, 已取消更新."
    return 1
  }
  chmod 755 "$candidate"
  if ! atomic_install_file 755 "$candidate" "$MANAGER_INSTALLED_SCRIPT" || \
     ! write_manager_install_marker "$candidate_version"; then
    restore_component_rollback manager || true
    rm -rf -- "$temporary_dir"
    echo "管理器更新失败, 已尝试恢复原版本."
    return 1
  fi
  rm -rf -- "$temporary_dir"
  echo "MiPilot 已更新到 ${candidate_version}."
  echo "当前菜单仍是旧进程, 退出后请重新执行 mipilot."
  MANAGER_SHOULD_EXIT=1
}

online_update_geo() {
  local temporary_dir
  local base="https://github.com/MetaCubeX/meta-rules-dat/releases/download/latest"

  temporary_dir="$(mktemp -d /tmp/mipilot-online-geo.XXXXXX)" || return 1
  for file in country.mmdb country.mmdb.sha256sum geosite.dat geosite.dat.sha256sum; do
    if ! download_file "${base}/${file}" "${temporary_dir}/${file}" "$file"; then
      rm -rf -- "$temporary_dir"
      show_manual_download_help
      return 1
    fi
  done
  if ! verify_sha256_sidecar "${temporary_dir}/country.mmdb" "${temporary_dir}/country.mmdb.sha256sum" || \
     ! verify_sha256_sidecar "${temporary_dir}/geosite.dat" "${temporary_dir}/geosite.dat.sha256sum"; then
    echo "地理数据SHA256校验失败, 未执行更新."
    rm -rf -- "$temporary_dir"
    return 1
  fi
  update_geo_from_files "${temporary_dir}/country.mmdb" "${temporary_dir}/geosite.dat"
  local status=$?
  rm -rf -- "$temporary_dir"
  return "$status"
}

download_latest_core_archive() {
  local output_file="$1"
  local release_json
  local asset_record
  local asset_url
  local digest
  local expected_hash
  local actual_hash

  release_json="$(mktemp /tmp/mihomo-latest-release.XXXXXX.json)" || return 1
