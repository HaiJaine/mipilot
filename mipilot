redact_sensitive_output() {
  sed -E \
    -e 's#(https?|ss|ssr|vmess|vless|trojan|hysteria2?|tuic|socks5?)://[^[:space:]]+#[REDACTED_URI]#Ig' \
    -e 's#(secret|password|token|authorization)[[:space:]]*[:=][[:space:]]*[^[:space:],}]+#\1=[REDACTED]#Ig' \
    -e 's#(Bearer|Basic)[[:space:]]+[A-Za-z0-9._~+/=-]+#\1 [REDACTED]#Ig'
}

generate_diagnostic_report() {
  local report
  local validation

  report="${USER_HOME}/mihomo-diagnostic-$(date +%Y%m%d-%H%M%S).txt"
  validation="$(sudo "$MIHOMO_BIN" -t -d "$CONFIG_DIR" 2>&1 || true)"
  {
    echo "mipilot Diagnostic"
    echo "generated_at=$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    echo "manager_version=${MANAGER_VERSION}"
    echo "kernel_version=$(current_core_version)"
    echo "service_active=$(systemctl is-active mihomo 2>/dev/null || true)"
    echo "service_enabled=$(systemctl is-enabled mihomo 2>/dev/null || true)"
    echo "tun=$(tun_config_value 2>/dev/null || true)"
    echo "mode=$(config_value mode 2>/dev/null || true)"
    echo "ports:"
    sudo grep -E '^(mixed-port|port|socks-port|external-controller):' "$CONFIG_FILE" 2>/dev/null \
      | sed -E 's#(secret:).*#\1 [REDACTED]#'
    echo "config_validation:"
    printf '%s\n' "$validation" \
      | redact_sensitive_output
    echo "recent_logs:"
    sudo journalctl -u mihomo -n 50 --no-pager 2>/dev/null \
      | redact_sensitive_output
  } >"$report"
  chmod 600 "$report"
  echo "脱敏诊断报告已保存: ${report}"
}

