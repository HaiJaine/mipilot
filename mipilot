resolve_main_proxy_response() {
  local response="$1"
  local running_mode="${2:-rule}"
  local current
  local next
  local depth
  local -A seen=()

  ACTIVE_NODE=""
  ACTIVE_CHAIN=""

  if [[ $running_mode == direct ]]; then
    ACTIVE_NODE="DIRECT"
    ACTIVE_CHAIN="DIRECT"
    return 0
  fi

  if [[ $running_mode == global ]] && jq -e '.proxies.GLOBAL != null' <<<"$response" >/dev/null; then
    current="GLOBAL"
  elif jq -e '.proxies["🚀节点选择"] != null' <<<"$response" >/dev/null; then
    current="🚀节点选择"
  elif jq -e '.proxies.GLOBAL != null' <<<"$response" >/dev/null; then
    current="GLOBAL"
  else
    return 1
  fi

  for ((depth = 0; depth < 16; depth++)); do
    if [[ -n ${seen[$current]+present} ]]; then
      ACTIVE_CHAIN+=" → [循环引用]"
      return 1
    fi
    seen["$current"]=1

    if [[ -n $ACTIVE_CHAIN ]]; then
      ACTIVE_CHAIN+=" → "
    fi
    ACTIVE_CHAIN+="$current"

    next="$(jq -r --arg name "$current" '.proxies[$name].now // empty' <<<"$response")"
    if [[ -z $next || $next == "$current" ]]; then
      ACTIVE_NODE="$current"
      return 0
    fi
    current="$next"
  done

  ACTIVE_CHAIN+=" → [层级过深]"
  return 1
}

resolve_main_proxy() {
  local running_mode="${1:-}"
  local config_response
  local response
  local status

  if [[ -z $running_mode ]]; then
    config_response="$(api "${API}/configs")"
    status=$?
    if (( status == 130 )); then return 130; fi
    if (( status != 0 )); then return 1; fi
    running_mode="$(jq -r '.mode // "rule"' <<<"$config_response")"
  fi

  response="$(api "${API}/proxies")"
  status=$?
  if (( status == 130 )); then return 130; fi
  if (( status != 0 )); then return 1; fi

  resolve_main_proxy_response "$response" "$running_mode"
}

